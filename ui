        local function ActivateTab(tabDataToActivate, isInit)
            local EXIT_T, ENTER_T = 0.2, 0.25

            if ActiveTab and ActiveTab ~= tabDataToActivate then
                Tween(ActiveTab.Btn,   {BackgroundTransparency=1}, EXIT_T)
                Tween(ActiveTab.Glow,  {ImageTransparency=1}, EXIT_T)
                Tween(ActiveTab.Label, {TextColor3=C.TextSub}, EXIT_T)
                Tween(ActiveTab.Icon,  {ImageColor3=ICON_INACTIVE}, EXIT_T)
                if ActiveTab.SecIcon then
                    Tween(ActiveTab.SecIcon, {ImageColor3=ICON_INACTIVE}, EXIT_T)
                end
                Tween(ActiveTab.Ind,   {Size=UDim2.new(0,3,0,0)}, EXIT_T)
            end

            Tween(tabDataToActivate.Btn,    {BackgroundTransparency=0.85}, ENTER_T)
            Tween(tabDataToActivate.Glow,   {ImageTransparency=0.5}, ENTER_T)
            Tween(tabDataToActivate.Label,  {TextColor3=C.Text}, ENTER_T)
            Tween(tabDataToActivate.Icon,   {ImageColor3=ICON_ACTIVE}, ENTER_T)
            if tabDataToActivate.SecIcon then
                Tween(tabDataToActivate.SecIcon, {ImageColor3=C.Primary}, ENTER_T)
            end
            Tween(tabDataToActivate.Ind, {Size=UDim2.new(0,3,0,20)}, 0.3, Enum.EasingStyle.Bounce)

            if not isInit and ActiveTab then
                local old = ActiveTab.Page
                ActiveTab = tabDataToActivate
                Tween(old, {GroupTransparency=1, Position=UDim2.new(-0.1,0,0,0)}, EXIT_T, Enum.EasingStyle.Sine)
                task.delay(EXIT_T, function()
                    old.Visible=false; old.GroupTransparency=0; old.Position=UDim2.new(0,0,0,0)
                    tabDataToActivate.Page.Position=UDim2.new(0.1,0,0,0)
                    tabDataToActivate.Page.GroupTransparency=1; tabDataToActivate.Page.Visible=true
                    Tween(tabDataToActivate.Page, {GroupTransparency=0, Position=UDim2.new(0,0,0,0)}, ENTER_T, Enum.EasingStyle.Sine)
                end)
            elseif not isInit then
                ActiveTab = tabDataToActivate
                tabDataToActivate.Page.Position=UDim2.new(0.1,0,0,0)
                tabDataToActivate.Page.GroupTransparency=1; tabDataToActivate.Page.Visible=true
                Tween(tabDataToActivate.Page, {GroupTransparency=0, Position=UDim2.new(0,0,0,0)}, ENTER_T, Enum.EasingStyle.Sine)
            end
        end

        TabBtn.MouseButton1Click:Connect(function()
