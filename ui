    -- ────────────────────────────────────────────
    -- WINDOW OBJECT
    -- ────────────────────────────────────────────
    local Win = {}
    Win._sectionGroups = {}

    -- ── SECTION CATEGORY HEADERS IN SIDEBAR ──
    local sectionHeaders = {}
    local tabButtons     = {}
    local tabPages       = {}
    local currentTabPage = nil
    local currentTabBtn  = nil

    local function SelectTab(tabBtn, page, name)
        -- Deselect previous
        if currentTabBtn then
            Tween(currentTabBtn._icon, {ImageColor3 = TEXT_MUTED}, TWEEN_MED)
            Tween(currentTabBtn._indicator, {BackgroundTransparency = 1, Size = UDim2.new(0, 2, 0, 0)}, TWEEN_MED)
            Tween(currentTabBtn._bg, {BackgroundTransparency = 1}, TWEEN_MED)
        end
        if currentTabPage then
            currentTabPage.Visible = false
        end

        -- Select new
        currentTabBtn  = tabBtn
        currentTabPage = page
        Tween(tabBtn._icon, {ImageColor3 = ACCENT_LIGHT}, TWEEN_MED)
        Tween(tabBtn._indicator, {BackgroundTransparency = 0, Size = UDim2.new(0, 3, 0, 28)}, TWEEN_SPRING)
        Tween(tabBtn._bg, {BackgroundTransparency = 0.7}, TWEEN_MED)
        page.Visible = true
        TopTabName.Text = name
    end

    -- ── CREATE SECTION CATEGORY (e.g. "MAIN", "COMBAT") ──
    function Win:AddCategory(name)
        local catLabel = Create("TextLabel", {
            Size = UDim2.new(1, 0, 0, 20),
            BackgroundTransparency = 1,
            Text = name,
            TextColor3 = ACCENT,
            Font = Enum.Font.GothamBlack,
            TextSize = 8,
            TextXAlignment = Enum.TextXAlignment.Center,
            LayoutOrder = #sectionHeaders * 100,
            ZIndex = 4,
            Parent = SidebarScroll,
        })
        table.insert(sectionHeaders, catLabel)

        local Cat = {}
        Cat._label = catLabel
        Cat._tabs  = {}

        function Cat:AddTab(tabConfig)
            tabConfig = tabConfig or {}
            local tabName  = tabConfig.Name  or "Tab"
            local iconId   = tabConfig.Icon  or ICONS.default
            local tabOrder = #Cat._tabs * 10 + catLabel.LayoutOrder + 1

            -- Sidebar button
            local btnHolder = Create("Frame", {
                Size = UDim2.new(1, 0, 0, 46),
                BackgroundTransparency = 1,
                LayoutOrder = tabOrder,
                ZIndex = 4,
                Parent = SidebarScroll,
            })

            local btnBg = Create("Frame", {
                Size = UDim2.new(1, -6, 1, -6),
                Position = UDim2.new(0, 3, 0, 3),
                BackgroundColor3 = ACCENT_DARK,
                BackgroundTransparency = 1,
                ZIndex = 4,
                Parent = btnHolder,
            })
            AddCorner(btnBg, 8)

            local indicator = Create("Frame", {
                Size = UDim2.new(0, 3, 0, 0),
                Position = UDim2.new(0, 0, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                BackgroundColor3 = ACCENT,
                BackgroundTransparency = 1,
                ZIndex = 5,
                Parent = btnHolder,
            })
            AddCorner(indicator, 2)

            local icon = Create("ImageLabel", {
                Size = UDim2.new(0, 22, 0, 22),
                Position = UDim2.new(0.5, -11, 0.5, -11),
                BackgroundTransparency = 1,
                Image = iconId,
                ImageColor3 = TEXT_MUTED,
                ZIndex = 5,
                Parent = btnHolder,
            })

            local tooltip = Create("TextLabel", {
                Size = UDim2.new(0, 90, 0, 24),
                Position = UDim2.new(1, 8, 0.5, -12),
                BackgroundColor3 = BG_CARD2,
                Text = tabName,
                TextColor3 = TEXT_PRIMARY,
                Font = Enum.Font.GothamSemibold,
                TextSize = 11,
                Visible = false,
                ZIndex = 20,
                Parent = btnHolder,
            })
            AddCorner(tooltip, 4)
            AddStroke(tooltip, BORDER, 1)

            -- Hover tooltip
            local clickbtn = Create("TextButton", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = "",
                ZIndex = 6,
                Parent = btnHolder,
            })
            clickbtn.MouseEnter:Connect(function()
                tooltip.Visible = true
                Tween(icon, {ImageColor3 = ACCENT_LIGHT}, TWEEN_FAST)
            end)
            clickbtn.MouseLeave:Connect(function()
                tooltip.Visible = false
                if currentTabBtn ~= btnObj then
                    Tween(icon, {ImageColor3 = TEXT_MUTED}, TWEEN_FAST)
                end
            end)

            -- Page
            local Page = Create("Frame", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Visible = false,
                ZIndex = 3,
                Parent = ContentArea,
            })

            -- Two-column layout
            local LeftCol = Create("ScrollingFrame", {
                Size = UDim2.new(0.5, -10, 1, -8),
                Position = UDim2.new(0, 8, 0, 4),
                BackgroundTransparency = 1,
                ScrollBarThickness = 2,
                ScrollBarImageColor3 = ACCENT,
                ZIndex = 3,
                Parent = Page,
            })
            AddListLayout(LeftCol, Enum.FillDirection.Vertical, 6)
            AddPadding(LeftCol, 4, 80, 4, 4)

            local RightCol = Create("ScrollingFrame", {
                Size = UDim2.new(0.5, -10, 1, -8),
                Position = UDim2.new(0.5, 2, 0, 4),
                BackgroundTransparency = 1,
                ScrollBarThickness = 2,
                ScrollBarImageColor3 = ACCENT,
                ZIndex = 3,
                Parent = Page,
            })
            AddListLayout(RightCol, Enum.FillDirection.Vertical, 6)
            AddPadding(RightCol, 4, 80, 4, 4)

            -- Fix canvas size via layout
            for _, col in ipairs({LeftCol, RightCol}) do
                local layout = col:FindFirstChildOfClass("UIListLayout")
                if layout then
                    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                        col.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
                    end)
                end
            end

            -- Sub-tab bar (Modes / Bite / Misc style)
            local SubTabBar = Create("Frame", {
                Size = UDim2.new(1, -8, 0, 36),
                Position = UDim2.new(0, 4, 0, 2),
                BackgroundTransparency = 1,
                ZIndex = 4,
                Parent = Page,
            })
            AddListLayout(SubTabBar, Enum.FillDirection.Horizontal, 4,
                Enum.HorizontalAlignment.Left, Enum.VerticalAlignment.Center)

            local subTabs = {}
            local currentSubTab = nil

            -- Shift columns down when subtab bar exists
            local function RepositionColumns()
                if #subTabs > 0 then
                    LeftCol.Position  = UDim2.new(0, 8, 0, 42)
                    LeftCol.Size      = UDim2.new(0.5, -10, 1, -46)
                    RightCol.Position = UDim2.new(0.5, 2, 0, 42)
                    RightCol.Size     = UDim2.new(0.5, -10, 1, -46)
                end
            end

            local btnObj = {
                _icon      = icon,
                _indicator = indicator,
                _bg        = btnBg,
            }

            clickbtn.MouseButton1Click:Connect(function()
                SelectTab(btnObj, Page, tabName)
            end)

            -- Auto-select first tab
            if #tabButtons == 0 and #Cat._tabs == 0 then
                SelectTab(btnObj, Page, tabName)
            end
            table.insert(tabButtons, btnObj)
            table.insert(Cat._tabs, btnObj)

            -- ── TAB API ──
            local Tab = {}
            Tab._leftCol  = LeftCol
            Tab._rightCol = RightCol
            Tab._page     = Page
            Tab._subTabs  = subTabs
            Tab._infoCards= {}

            -- ── ADD SUBTAB ──
            function Tab:AddSubTab(stName)
                local stBtn = Create("TextButton", {
                    Size = UDim2.new(0, 0, 1, 0),
                    AutomaticSize = Enum.AutomaticSize.X,
                    BackgroundTransparency = 1,
                    Text = stName,
                    TextColor3 = TEXT_MUTED,
                    Font = Enum.Font.GothamBold,
                    TextSize = 13,
                    ZIndex = 5,
                    Parent = SubTabBar,
                })
                AddPadding(stBtn, 4, 4, 10, 10)

                local underline = Create("Frame", {
                    Size = UDim2.new(1, 0, 0, 2),
                    Position = UDim2.new(0, 0, 1, -2),
                    BackgroundColor3 = ACCENT,
                    BackgroundTransparency = 1,
                    ZIndex = 6,
                    Parent = stBtn,
                })
                AddCorner(underline, 1)

                -- Content frame for this subtab
                local stContent = Create("Frame", {
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Visible = false,
                    ZIndex = 3,
                    Parent = Page,
                })

                local stLeftCol = Create("ScrollingFrame", {
                    Size = UDim2.new(0.5, -10, 1, -46),
                    Position = UDim2.new(0, 8, 0, 42),
                    BackgroundTransparency = 1,
                    ScrollBarThickness = 2,
                    ScrollBarImageColor3 = ACCENT,
                    ZIndex = 4,
                    Parent = stContent,
                })
                AddListLayout(stLeftCol, Enum.FillDirection.Vertical, 6)
                AddPadding(stLeftCol, 4, 80, 4, 4)
                do
                    local lay = stLeftCol:FindFirstChildOfClass("UIListLayout")
                    if lay then
                        lay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                            stLeftCol.CanvasSize = UDim2.new(0, 0, 0, lay.AbsoluteContentSize.Y + 20)
                        end)
                    end
                end

                local stRightCol = Create("ScrollingFrame", {
                    Size = UDim2.new(0.5, -10, 1, -46),
                    Position = UDim2.new(0.5, 2, 0, 42),
                    BackgroundTransparency = 1,
                    ScrollBarThickness = 2,
                    ScrollBarImageColor3 = ACCENT,
                    ZIndex = 4,
                    Parent = stContent,
                })
                AddListLayout(stRightCol, Enum.FillDirection.Vertical, 6)
                AddPadding(stRightCol, 4, 80, 4, 4)
                do
                    local lay = stRightCol:FindFirstChildOfClass("UIListLayout")
                    if lay then
                        lay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                            stRightCol.CanvasSize = UDim2.new(0, 0, 0, lay.AbsoluteContentSize.Y + 20)
                        end)
                    end
                end

                local stObj = {
                    btn = stBtn,
                    underline = underline,
                    content = stContent,
                    leftCol = stLeftCol,
                    rightCol = stRightCol,
                }
                table.insert(subTabs, stObj)
                RepositionColumns()

                -- Hide original columns when subtabs exist
                LeftCol.Visible  = false
                RightCol.Visible = false

                local function SelectSubTab(st)
                    if currentSubTab then
                        Tween(currentSubTab.btn, {TextColor3 = TEXT_MUTED}, TWEEN_FAST)
                        Tween(currentSubTab.underline, {BackgroundTransparency = 1}, TWEEN_FAST)
                        currentSubTab.content.Visible = false
                    end
                    currentSubTab = st
                    Tween(st.btn, {TextColor3 = TEXT_PRIMARY}, TWEEN_FAST)
                    Tween(st.underline, {BackgroundTransparency = 0}, TWEEN_FAST)
                    st.content.Visible = true
                end

                stBtn.MouseButton1Click:Connect(function()
                    SelectSubTab(stObj)
                end)

                if #subTabs == 1 then
                    SelectSubTab(stObj)
                end

                -- Return SubTab section API
                local SubTab = {}
                SubTab._leftCol  = stLeftCol
                SubTab._rightCol = stRightCol

                -- Embed AddSection / components into SubTab
                local function buildSectionAPI(col)
                    return Tab:_AddSectionToCol(col)
                end

                function SubTab:AddSection(secConfig)
                    secConfig = secConfig or {}
                    local column = secConfig.Column or "Left"
                    local col = column == "Right" and stRightCol or stLeftCol
                    return Tab:_AddSectionToCol(col, secConfig)
                end

                function SubTab:AddInfoCards(cards)
                    return Tab:_AddInfoCards(stLeftCol, cards)
                end

                return SubTab
            end

            -- ── INTERNAL: CREATE SECTION CARD ──
            function Tab:_AddSectionToCol(col, secConfig)
                secConfig = secConfig or {}
                local secName = secConfig.Name or ""

                local card = Create("Frame", {
                    Size = UDim2.new(1, -4, 0, 0),
                    AutomaticSize = Enum.AutomaticSize.Y,
                    BackgroundColor3 = BG_CARD,
                    ZIndex = 4,
                    Parent = col,
                })
                AddCorner(card, 10)
                AddStroke(card, BORDER, 1)
                Create("UIGradient", {
                    Color = ColorSequence.new({
                        ColorSequenceKeypoint.new(0, Color3.fromRGB(24, 22, 42)),
                        ColorSequenceKeypoint.new(1, Color3.fromRGB(18, 18, 32)),
                    }),
                    Rotation = 135,
                    Parent = card,
                })

                local itemList = Create("Frame", {
                    Size = UDim2.new(1, 0, 0, 0),
                    AutomaticSize = Enum.AutomaticSize.Y,
                    BackgroundTransparency = 1,
                    ZIndex = 4,
                    Parent = card,
                })
                AddListLayout(itemList, Enum.FillDirection.Vertical, 0)
                AddPadding(itemList, 6, 6, 8, 8)

                local yOffset = 0

                if secName ~= "" then
                    local hdr = Create("TextLabel", {
                        Size = UDim2.new(1, 0, 0, 22),
                        BackgroundTransparency = 1,
                        Text = secName,
                        TextColor3 = ACCENT_LIGHT,
                        Font = Enum.Font.GothamBold,
                        TextSize = 11,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        ZIndex = 5,
                        Parent = itemList,
                    })
                    yOffset = 22
                end

                -- ── SECTION API ──
                local Sec = {}
                Sec._card    = card
                Sec._list    = itemList

                -- Helper: row container
                local function MakeRow(height)
                    local row = Create("Frame", {
                        Size = UDim2.new(1, 0, 0, height or 36),
                        BackgroundTransparency = 1,
                        ZIndex = 5,
                        Parent = itemList,
                    })
                    return row
                end

                local function MakeSeparator()
                    Create("Frame", {
                        Size = UDim2.new(1, -8, 0, 1),
                        Position = UDim2.new(0, 4, 0, 0),
                        BackgroundColor3 = BORDER,
                        BackgroundTransparency = 0.5,
                        ZIndex = 5,
                        Parent = itemList,
                    })
                end

                -- ── BUTTON ──
                function Sec:CreateButton(cfg)
                    cfg = cfg or {}
                    local row = MakeRow(38)
                    local btn = Create("TextButton", {
                        Size = UDim2.new(1, -4, 0, 30),
                        Position = UDim2.new(0, 2, 0.5, -15),
                        BackgroundColor3 = BG_ITEM,
                        Text = "",
                        ZIndex = 6,
                        Parent = row,
                    })
                    AddCorner(btn, 7)
                    AddStroke(btn, Color3.fromRGB(40, 35, 70), 1)
                    Create("TextLabel", {
                        Size = UDim2.new(1, -16, 1, 0),
                        Position = UDim2.new(0, 10, 0, 0),
                        BackgroundTransparency = 1,
                        Text = cfg.Name or "Button",
                        TextColor3 = TEXT_PRIMARY,
                        Font = Enum.Font.GothamSemibold,
                        TextSize = 12,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        ZIndex = 7,
                        Parent = btn,
                    })
                    HoverEffect(btn, BG_ITEM, Color3.fromRGB(32, 28, 55))
                    RippleEffect(btn)
                    btn.MouseButton1Click:Connect(function()
                        Tween(btn, {BackgroundColor3 = ACCENT_DARK}, TWEEN_FAST)
                        task.delay(0.15, function() Tween(btn, {BackgroundColor3 = BG_ITEM}, TWEEN_MED) end)
                        if cfg.Callback then cfg.Callback() end
                    end)
                    MakeSeparator()
                    return btn
                end

                -- ── TOGGLE ──
                function Sec:CreateToggle(cfg)
                    cfg = cfg or {}
                    local flagKey = cfg.Flag
                    local state   = cfg.Default or false
                    if flagKey then Library.Flags[flagKey] = state end

                    local row = MakeRow(40)

                    Create("TextLabel", {
                        Size = UDim2.new(0.65, -10, 0, 16),
                        Position = UDim2.new(0, 10, 0.2, 0),
                        BackgroundTransparency = 1,
                        Text = cfg.Name or "Toggle",
                        TextColor3 = TEXT_PRIMARY,
                        Font = Enum.Font.GothamSemibold,
                        TextSize = 12,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        ZIndex = 6,
                        Parent = row,
                    })
                    if cfg.Description then
                        Create("TextLabel", {
                            Size = UDim2.new(0.65, -10, 0, 12),
                            Position = UDim2.new(0, 10, 0.55, 0),
                            BackgroundTransparency = 1,
                            Text = cfg.Description,
                            TextColor3 = TEXT_MUTED,
                            Font = Enum.Font.Gotham,
                            TextSize = 9,
                            TextXAlignment = Enum.TextXAlignment.Left,
                            ZIndex = 6,
                            Parent = row,
                        })
                    end

                    -- iOS switch
                    local track = Create("Frame", {
                        Size = UDim2.new(0, 44, 0, 22),
                        Position = UDim2.new(1, -52, 0.5, -11),
                        BackgroundColor3 = state and ACCENT or TOGGLE_OFF,
                        ZIndex = 6,
                        Parent = row,
                    })
                    AddCorner(track, 11)
                    local knob = Create("Frame", {
                        Size = UDim2.new(0, 16, 0, 16),
                        Position = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8),
                        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                        ZIndex = 7,
                        Parent = track,
                    })
                    AddCorner(knob, 8)
                    -- glow
                    Create("UIGradient", {
                        Color = ColorSequence.new({
                            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
                            ColorSequenceKeypoint.new(1, Color3.fromRGB(220, 220, 240)),
                        }),
                        Rotation = 135,
                        Parent = knob,
                    })

                    local clickArea = Create("TextButton", {
                        Size = UDim2.new(1, 0, 1, 0),
                        BackgroundTransparency = 1,
                        Text = "",
                        ZIndex = 8,
                        Parent = row,
                    })
                    clickArea.MouseButton1Click:Connect(function()
                        state = not state
                        if flagKey then Library.Flags[flagKey] = state end
                        Tween(track, {BackgroundColor3 = state and ACCENT or TOGGLE_OFF}, TWEEN_MED)
                        Tween(knob, {
                            Position = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
                        }, TWEEN_MED)
                        if cfg.Callback then cfg.Callback(state) end
                    end)

                    MakeSeparator()

                    local Toggle = {}
                    function Toggle:Set(val)
                        state = val
                        if flagKey then Library.Flags[flagKey] = state end
                        Tween(track, {BackgroundColor3 = state and ACCENT or TOGGLE_OFF}, TWEEN_MED)
                        Tween(knob, {
                            Position = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
                        }, TWEEN_MED)
                    end
                    function Toggle:Get() return state end
                    return Toggle
                end

                -- ── SLIDER ──
                function Sec:CreateSlider(cfg)
                    cfg = cfg or {}
                    local flagKey = cfg.Flag
                    local minVal  = cfg.Min     or 0
                    local maxVal  = cfg.Max     or 100
                    local defVal  = cfg.Default or minVal
                    local suffix  = cfg.Suffix  or ""
                    local curVal  = defVal
                    if flagKey then Library.Flags[flagKey] = curVal end

                    local row = MakeRow(50)

                    local nameLabel = Create("TextLabel", {
                        Size = UDim2.new(0.7, -10, 0, 16),
                        Position = UDim2.new(0, 10, 0, 6),
                        BackgroundTransparency = 1,
                        Text = cfg.Name or "Slider",
                        TextColor3 = TEXT_PRIMARY,
                        Font = Enum.Font.GothamSemibold,
                        TextSize = 12,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        ZIndex = 6,
                        Parent = row,
                    })
                    local valLabel = Create("TextLabel", {
                        Size = UDim2.new(0.3, -8, 0, 16),
                        Position = UDim2.new(0.7, 0, 0, 6),
                        BackgroundTransparency = 1,
                        Text = tostring(defVal) .. suffix,
                        TextColor3 = ACCENT_LIGHT,
                        Font = Enum.Font.GothamBold,
                        TextSize = 12,
                        TextXAlignment = Enum.TextXAlignment.Right,
                        ZIndex = 6,
                        Parent = row,
                    })

                    local trackBg = Create("Frame", {
                        Size = UDim2.new(1, -20, 0, 6),
                        Position = UDim2.new(0, 10, 0, 30),
                        BackgroundColor3 = BG_ITEM,
                        ZIndex = 6,
                        Parent = row,
                    })
                    AddCorner(trackBg, 3)
                    AddStroke(trackBg, BORDER, 1)

                    local rel0  = (defVal - minVal) / (maxVal - minVal)
                    local fill  = Create("Frame", {
                        Size = UDim2.new(rel0, 0, 1, 0),
                        BackgroundColor3 = ACCENT,
                        ZIndex = 7,
                        Parent = trackBg,
                    })
                    AddCorner(fill, 3)
                    Create("UIGradient", {
                        Color = ColorSequence.new({
                            ColorSequenceKeypoint.new(0, ACCENT),
                            ColorSequenceKeypoint.new(1, ACCENT_LIGHT),
                        }),
                        Rotation = 0,
                        Parent = fill,
                    })

                    local knob2 = Create("Frame", {
                        Size = UDim2.new(0, 14, 0, 14),
                        Position = UDim2.new(rel0, -7, 0.5, -7),
                        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                        ZIndex = 8,
                        Parent = trackBg,
                    })
                    AddCorner(knob2, 7)

                    local dragging2 = false
                    trackBg.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1
                            or input.UserInputType == Enum.UserInputType.Touch then
                            dragging2 = true
                        end
                    end)
                    trackBg.InputEnded:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1
                            or input.UserInputType == Enum.UserInputType.Touch then
                            dragging2 = false
                        end
                    end)
                    UserInputService.InputChanged:Connect(function(input)
                        if dragging2 and (
                            input.UserInputType == Enum.UserInputType.MouseMovement
                            or input.UserInputType == Enum.UserInputType.Touch) then
                            local r = (input.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X
                            r = math.clamp(r, 0, 1)
                            curVal = math.floor(minVal + r * (maxVal - minVal))
                            if flagKey then Library.Flags[flagKey] = curVal end
                            fill.Size = UDim2.new(r, 0, 1, 0)
                            knob2.Position = UDim2.new(r, -7, 0.5, -7)
                            valLabel.Text = tostring(curVal) .. suffix
                            if cfg.Callback then cfg.Callback(curVal) end
                        end
                    end)

                    MakeSeparator()

                    local Slider = {}
                    function Slider:Set(val)
                        curVal = math.clamp(val, minVal, maxVal)
                        if flagKey then Library.Flags[flagKey] = curVal end
                        local r2 = (curVal - minVal) / (maxVal - minVal)
                        fill.Size = UDim2.new(r2, 0, 1, 0)
                        knob2.Position = UDim2.new(r2, -7, 0.5, -7)
                        valLabel.Text = tostring(curVal) .. suffix
                    end
                    function Slider:Get() return curVal end
                    return Slider
                end

                -- ── DROPDOWN ──
                function Sec:CreateDropdown(cfg)
                    cfg = cfg or {}
