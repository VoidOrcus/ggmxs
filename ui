        Dark    = Color3.fromRGB( 20,  15,  30),
        Border  = Color3.fromRGB( 60,  35,  90),
        Text    = Color3.fromRGB(255, 255, 255),
        TextSub = Color3.fromRGB(160, 150, 190),
    }
    -- Cores fixas da interface: options.Colors é ignorado de propósito.
    local PaletteRefs = {}
    for k in pairs(C) do PaletteRefs[k] = {} end

    local function RefColor(key, obj, prop)
        if PaletteRefs[key] then
            table.insert(PaletteRefs[key], {obj, prop})
        end
    end

    local function SetPaletteColor(key, newColor)
        C[key] = newColor
        for _, r in ipairs(PaletteRefs[key] or {}) do
            pcall(function() r[1][r[2]] = newColor end)
        end
    end

    local function ColorToHex(c)
        return string.format("%02X%02X%02X",
            math.floor(c.R*255), math.floor(c.G*255), math.floor(c.B*255))
    end
    local function HexToColor(hex)
        hex = hex:gsub("#","")
        local r = tonumber(hex:sub(1,2),16) or 0
        local g = tonumber(hex:sub(3,4),16) or 0
        local b = tonumber(hex:sub(5,6),16) or 0
        return Color3.fromRGB(r,g,b)
    end

