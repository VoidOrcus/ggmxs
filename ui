                local rowsContainer = Instance.new("Frame", f)
                rowsContainer.Size = UDim2.new(1, 0, 0, 0)
                rowsContainer.Position = UDim2.new(0, 0, 0, 38)
                rowsContainer.BackgroundTransparency = 1
                rowsContainer.AutomaticSize = Enum.AutomaticSize.Y
                local rowsLayout = Instance.new("UIListLayout", rowsContainer)
                rowsLayout.SortOrder = Enum.SortOrder.LayoutOrder
                rowsLayout.Padding = UDim.new(0, 0)

                local emptyLbl = Instance.new("TextLabel", rowsContainer)
                emptyLbl.Size = UDim2.new(1, 0, 0, 36)
                emptyLbl.BackgroundTransparency = 1
                emptyLbl.Text = "No data available"
                emptyLbl.TextColor3 = C.TextSub
                emptyLbl.Font = Enum.Font.Gotham
                emptyLbl.TextSize = 10
                emptyLbl.Visible = true
                RefColor("TextSub", emptyLbl, "TextColor3")

                local rowCount = 0
                local statObj = {}

                function statObj:AddRow(labelText, valueText)
                    rowCount = rowCount + 1
                    emptyLbl.Visible = false

                    local row = Instance.new("Frame", rowsContainer)
                    row.Size = UDim2.new(1, 0, 0, 28)
                    row.BackgroundTransparency = 1
                    row.LayoutOrder = rowCount
                    row.BorderSizePixel = 0

                    if rowCount % 2 == 0 then
                        row.BackgroundColor3 = Color3.fromRGB(30, 22, 42)
                        row.BackgroundTransparency = 0.3
                    end

                    local sep = Instance.new("Frame", row)
                    sep.Size = UDim2.new(1, -24, 0, 1)
                    sep.Position = UDim2.new(0, 12, 0, 0)
                    sep.BackgroundColor3 = C.Border
                    sep.BackgroundTransparency = 0.7
                    sep.BorderSizePixel = 0
                    RefColor("Border", sep, "BackgroundColor3")

                    local keyLbl = Instance.new("TextLabel", row)
                    keyLbl.Size = UDim2.new(0.55, -12, 1, -1)
                    keyLbl.Position = UDim2.new(0, 12, 0, 1)
                    keyLbl.BackgroundTransparency = 1
                    keyLbl.Text = labelText
                    keyLbl.TextColor3 = C.TextSub
                    keyLbl.Font = Enum.Font.GothamMedium
                    keyLbl.TextSize = 10
                    keyLbl.TextXAlignment = 0
                    keyLbl.TextTruncate = Enum.TextTruncate.AtEnd
                    RefColor("TextSub", keyLbl, "TextColor3")

                    local valLbl = Instance.new("TextLabel", row)
                    valLbl.Size = UDim2.new(0.45, -12, 1, -1)
                    valLbl.Position = UDim2.new(0.55, 0, 0, 1)
                    valLbl.BackgroundTransparency = 1
                    valLbl.Text = tostring(valueText)
                    valLbl.TextColor3 = C.Text
                    valLbl.Font = Enum.Font.GothamBold
                    valLbl.TextSize = 10
                    valLbl.TextXAlignment = 1
                    valLbl.TextTruncate = Enum.TextTruncate.AtEnd
                    RefColor("Text", valLbl, "TextColor3")

                    return {
                        setLabel = function(txt) keyLbl.Text = txt end,
                        setValue = function(txt) valLbl.Text = tostring(txt) end,
                        setColor = function(col) valLbl.TextColor3 = col end,
                    }
                end

                function statObj:Clear()
                    rowCount = 0
                    for _, c in ipairs(rowsContainer:GetChildren()) do
                        if c ~= emptyLbl and c:IsA("Frame") then c:Destroy() end
                    end
                    emptyLbl.Visible = true
                end

                return statObj
            end

