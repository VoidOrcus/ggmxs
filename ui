            task.delay(0.1, function()
                ActiveIndicator.Position = UDim2.new(0, 0, 0, TabBtn.AbsolutePosition.Y - Sidebar.AbsolutePosition.Y + 6)
                ActiveIndicator.Size = UDim2.new(0, 3, 0, 24)
            end)
