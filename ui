        BackgroundTransparency = 1, Text = "Default", TextColor3 = Theme.Text, Font = Fonts.Text, TextSize = 13, PlaceholderText = "Config Name...", TextXAlignment = Enum.TextXAlignment.Left
    })
    
    ConfigTab:CreateButton("💾 Save Configuration", function()
        WindowObj.SaveConfig(CfgNameBox.Text)
