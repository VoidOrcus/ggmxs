-- STARRY BACKGROUND
-- ────────────────────────────────────────────────
local function CreateStarField(parent)
    local starCanvas = Create("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ZIndex = 0,
        Parent = parent,
    })
    math.randomseed(42)
    for i = 1, 80 do
        local x = math.random(0, 1000) / 1000
        local y = math.random(0, 1000) / 1000
        local sz = math.random(1, 3)
        local alpha = math.random(30, 80) / 100
        local star = Create("Frame", {
            Size = UDim2.new(0, sz, 0, sz),
            Position = UDim2.new(x, 0, y, 0),
            BackgroundColor3 = Color3.fromRGB(200, 180, 255),
            BackgroundTransparency = alpha,
            ZIndex = 1,
            Parent = starCanvas,
        })
        AddCorner(star, 50)

        -- Subtle twinkle
        local delay = math.random(0, 300) / 100
        task.delay(delay, function()
            local function twinkle()
                if not star or not star.Parent then return end
                Tween(star, {BackgroundTransparency = math.random(20, 70)/100},
                    TweenInfo.new(math.random(10,30)/10, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut))
                task.delay(math.random(10, 30)/10, twinkle)
            end
            twinkle()
        end)
    end
    return starCanvas
end

-- ────────────────────────────────────────────────
-- DRAGGABLE
-- ────────────────────────────────────────────────
local function MakeDraggable(handle, target)
    local dragging = false
    local dragStart, startPos

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos  = target.Position
        end
    end)

    handle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (
            input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            target.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

