            -- ── ADD SUBTAB ──
            function Tab:AddSubTab(stName)
                local stBtn = Create("TextButton", {
                    Size             = UDim2.new(0, 0, 1, 0),
                    AutomaticSize    = Enum.AutomaticSize.X,
                    BackgroundTransparency = 1,
                    Text             = stName,
                    TextColor3       = TEXT_MUTED,
                    Font             = Enum.Font.GothamBold,
                    TextSize         = 13,
                    ZIndex           = 5,
                    Parent           = SubTabBar,
                })
                AddPadding(stBtn, 4, 4, 12, 12)
                local underline = Create("Frame", {
                    Size             = UDim2.new(1, 0, 0, 2),
                    Position         = UDim2.new(0, 0, 1, -2),
                    BackgroundColor3 = ACCENT,
                    BackgroundTransparency = 1,
                    ZIndex           = 6,
                    Parent           = stBtn,
                })
                AddCorner(underline, 1)

                local stContent = Create("Frame", {
                    Size             = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Visible          = false,
                    ZIndex           = 3,
                    Parent           = Page,
                })
                local function makeSubCol(xPos, xSize)
                    local sc = Create("ScrollingFrame", {
                        Size             = UDim2.new(xSize, -10, 1, -52),
                        Position         = UDim2.new(xPos, (xPos==0 and 8 or 2), 0, 48),
                        BackgroundTransparency = 1,
                        ScrollBarThickness = 2,
                        ScrollBarImageColor3 = ACCENT,
                        ZIndex           = 4,
                        Parent           = stContent,
                    })
                    AddListLayout(sc, Enum.FillDirection.Vertical, 8)
                    AddPadding(sc, 4, 80, 4, 4)
                    local lay = sc:FindFirstChildOfClass("UIListLayout")
                    if lay then
                        lay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                            sc.CanvasSize = UDim2.new(0, 0, 0, lay.AbsoluteContentSize.Y + 20)
                        end)
                    end
                    return sc
                end
                local stLeft  = makeSubCol(0,   0.5)
                local stRight = makeSubCol(0.5, 0.5)

                local stObj = {btn=stBtn, underline=underline, content=stContent,
                               leftCol=stLeft, rightCol=stRight}
                table.insert(subTabs, stObj)
                RepositionColumns()
                LeftCol.Visible  = false
                RightCol.Visible = false

                local function SelectSubTab(st)
                    if currentSubTab then
                        Tween(currentSubTab.btn, {TextColor3 = TEXT_MUTED}, TWEEN_FAST)
                        Tween(currentSubTab.underline, {BackgroundTransparency = 1}, TWEEN_FAST)
                        currentSubTab.content.Visible = false
                    end
                    currentSubTab = st
                    Tween(st.btn, {TextColor3 = TEXT_PRIMARY}, TWEEN_FAST)
                    Tween(st.underline, {BackgroundTransparency = 0}, TWEEN_FAST)
                    st.content.Visible = true
                end

                stBtn.MouseButton1Click:Connect(function() SelectSubTab(stObj) end)
                if #subTabs == 1 then SelectSubTab(stObj) end

                local SubTab = {}
                function SubTab:AddSection(secConfig)
                    secConfig = secConfig or {}
                    local col = (secConfig.Column == "Right") and stRight or stLeft
                    return Tab:_AddSectionToCol(col, secConfig)
                end
                function SubTab:AddInfoCards(cards)
                    return Tab:_AddInfoCards(stLeft, cards)
                end
                return SubTab
            end

