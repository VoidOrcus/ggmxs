            C_Pad.PaddingRight = UDim.new(0, 12)

            -- MÁGICA DO SCROLL: Mede qual coluna está maior e expande o Canvas!
            local function UpdateCanvas()
                local MIN_H = 60

                local lh = L_Lay.AbsoluteContentSize.Y + 24
                local rh = R_Lay.AbsoluteContentSize.Y + 24
                local columnsH = math.max(lh, rh)

                local centerH = 0
                if CenterCol.Visible then
                    CenterCol.Position = UDim2.new(0.25, 0, 0, columnsH + 8)
                    centerH = C_Lay.AbsoluteContentSize.Y + 12
                end

                local contentH = columnsH + centerH
                if CenterCol.Visible then
                    contentH = contentH + 8
                end

                local availableH
                if showContents then
                    availableH = ContentArea.AbsoluteSize.Y - INFO_H - CONTENT_GAP - TOP_PAD - BOTTOM_PAD
                else
                    availableH = ContentArea.AbsoluteSize.Y - TOP_PAD - BOTTOM_PAD
                end

                -- Proteção para quando AbsoluteSize ainda está 0 durante carregamento/animação
                if not availableH or availableH <= 0 then
                    availableH = MIN_H
                end

                local minH = math.min(MIN_H, availableH)
                local finalH = math.clamp(contentH, minH, availableH)

                MainBox.Size = UDim2.new(1, -60, 0, finalH)
                InnerClip.CanvasSize = UDim2.new(0, 0, 0, contentH)

                if contentH > finalH then
                    InnerClip.ScrollBarThickness = 2
                    InnerClip.ScrollingEnabled = true
                else
                    InnerClip.ScrollBarThickness = 0
                    InnerClip.ScrollingEnabled = false
                end
            end

            subObj._updateCanvas = UpdateCanvas

            L_Lay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(UpdateCanvas)
            R_Lay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(UpdateCanvas)
            C_Lay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(UpdateCanvas)
            ContentArea:GetPropertyChangedSignal("AbsoluteSize"):Connect(UpdateCanvas)

            task.defer(function()
                task.wait()
                UpdateCanvas()
            end)

            subObj.Left  = LeftCol
