                            BackgroundTransparency = 1,
                            Text             = cfg.Description,
                            TextColor3       = TEXT_MUTED,
                            Font             = Enum.Font.Gotham,
                            TextSize         = 9,
                            TextXAlignment   = Enum.TextXAlignment.Left,
                            ZIndex           = 6,
                            Parent           = row,
                        })
                    end
                    local valLabel = Create("TextLabel", {
                        Size             = UDim2.new(0.3, -8, 0, 16),
                        Position         = UDim2.new(0.7, 0, 0, 6),
                        BackgroundTransparency = 1,
                        Text             = tostring(defV) .. suffix,
                        TextColor3       = ACCENT_LIGHT,
                        Font             = Enum.Font.GothamBold,
                        TextSize         = 12,
                        TextXAlignment   = Enum.TextXAlignment.Right,
                        ZIndex           = 6,
                        Parent           = row,
                    })
                    local trackBg = Create("Frame", {
                        Size             = UDim2.new(1, -20, 0, 6),
                        Position         = UDim2.new(0, 10, 0, 36),
                        BackgroundColor3 = BG_ITEM,
                        ZIndex           = 6,
                        Parent           = row,
                    })
                    AddCorner(trackBg, 3)
                    AddStroke(trackBg, BORDER, 1)
                    local rel0 = (defV - minV) / (maxV - minV)
                    local fill = Create("Frame", {
                        Size             = UDim2.new(rel0, 0, 1, 0),
                        BackgroundColor3 = ACCENT,
                        ZIndex           = 7,
                        Parent           = trackBg,
                    })
                    AddCorner(fill, 3)
                    Create("UIGradient", {
                        Color = ColorSequence.new({
                            ColorSequenceKeypoint.new(0, ACCENT),
                            ColorSequenceKeypoint.new(1, ACCENT_LIGHT),
                        }),
                        Parent = fill,
                    })
                    local knob2 = Create("Frame", {
                        Size             = UDim2.new(0, 14, 0, 14),
                        Position         = UDim2.new(rel0, -7, 0.5, -7),
                        BackgroundColor3 = Color3.fromRGB(255,255,255),
                        ZIndex           = 8,
                        Parent           = trackBg,
                    })
                    AddCorner(knob2, 7)
                    local drag2 = false
                    trackBg.InputBegan:Connect(function(i)
                        if i.UserInputType == Enum.UserInputType.MouseButton1
                            or i.UserInputType == Enum.UserInputType.Touch then drag2 = true end
                    end)
                    trackBg.InputEnded:Connect(function(i)
                        if i.UserInputType == Enum.UserInputType.MouseButton1
                            or i.UserInputType == Enum.UserInputType.Touch then drag2 = false end
                    end)
                    UserInputService.InputChanged:Connect(function(i)
                        if drag2 and (i.UserInputType == Enum.UserInputType.MouseMovement
                            or i.UserInputType == Enum.UserInputType.Touch) then
                            local r = math.clamp((i.Position.X - trackBg.AbsolutePosition.X)/trackBg.AbsoluteSize.X, 0, 1)
                            curVal = math.floor(minV + r * (maxV - minV))
                            if flagKey then Library.Flags[flagKey] = curVal end
                            fill.Size = UDim2.new(r, 0, 1, 0)
                            knob2.Position = UDim2.new(r, -7, 0.5, -7)
                            valLabel.Text = tostring(curVal) .. suffix
                            if cfg.Callback then cfg.Callback(curVal) end
                        end
                    end)
                    MakeSep()
                    local Slider = {}
                    function Slider:Set(v)
                        curVal = math.clamp(v, minV, maxV)
                        if flagKey then Library.Flags[flagKey] = curVal end
                        local r2 = (curVal - minV)/(maxV - minV)
                        fill.Size = UDim2.new(r2, 0, 1, 0)
                        knob2.Position = UDim2.new(r2, -7, 0.5, -7)
                        valLabel.Text = tostring(curVal) .. suffix
                    end
                    function Slider:Get() return curVal end
                    return Slider
                end

