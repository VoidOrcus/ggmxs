            function subObj:CreateSlider(title, desc, minV, maxV, default, cb)
                local val = default or minV
                local regEntry = { id = NewRegId("sld"), title = title }

                local f = Instance.new("Frame")
                f.Size = UDim2.new(1, 0, 0, 65)
                f.BackgroundColor3 = C.Card
                f.BorderSizePixel = 0
                Instance.new("UICorner", f).CornerRadius = UDim.new(0, 8)
                RefColor("Card", f, "BackgroundColor3")
                local slS = Instance.new("UIStroke", f)
                slS.Color = C.Primary; slS.Transparency = 0.6; slS.Thickness = 1
                RefColor("Primary", slS, "Color")
                self:_registerSmartItem(f, "slider", 1.25)

                local t = Instance.new("TextLabel", f)
                t.Size=UDim2.new(1,-60,0,16); t.Position=UDim2.new(0,12,0,10)
                t.BackgroundTransparency=1; t.Text=title; t.TextColor3=C.Text
                t.Font=Enum.Font.GothamBold; t.TextSize=12; t.TextXAlignment=0
                RefColor("Text", t, "TextColor3")

                local d = Instance.new("TextLabel", f)
                d.Size=UDim2.new(1,-60,0,12); d.Position=UDim2.new(0,12,0,30)
                d.BackgroundTransparency=1; d.Text=desc; d.TextColor3=C.TextSub
                d.Font=Enum.Font.Gotham; d.TextSize=10; d.TextXAlignment=0
                RefColor("TextSub", d, "TextColor3")

                local valBg = Instance.new("Frame", f)
                valBg.Size=UDim2.new(0,45,0,24); valBg.Position=UDim2.new(1,-55,0,15)
                valBg.BackgroundColor3=C.BgMain; valBg.BorderSizePixel=0
                Instance.new("UICorner", valBg).CornerRadius=UDim.new(0,6)
                RefColor("BgMain", valBg, "BackgroundColor3")

                local v = Instance.new("TextBox", valBg)
                v.Size=UDim2.new(1,0,1,0); v.BackgroundTransparency=1
                v.Text=string.format("%.2f",val); v.TextColor3=C.Text
                v.Font=Enum.Font.GothamMedium; v.TextSize=11
                v.ClearTextOnFocus = false
                RefColor("Text", v, "TextColor3")

                local trackArea = Instance.new("TextButton", f)
                trackArea.Size=UDim2.new(1,-24,0,16); trackArea.Position=UDim2.new(0,12,1,-18)
                trackArea.BackgroundTransparency=1; trackArea.Text=""

                local track = Instance.new("Frame", trackArea)
                track.Size=UDim2.new(1,0,0,4); track.Position=UDim2.new(0,0,0.5,-2)
                track.BackgroundColor3=Color3.fromRGB(50,40,60); track.BorderSizePixel=0
                Instance.new("UICorner", track)

                local pct = (val-minV)/(maxV-minV)
                local fill = Instance.new("Frame", track)
                fill.Size=UDim2.new(pct,0,1,0); fill.BackgroundColor3=C.Primary; fill.BorderSizePixel=0
                Instance.new("UICorner", fill)
                RefColor("Primary", fill, "BackgroundColor3")

                local knob = Instance.new("Frame", track)
                knob.Size=UDim2.new(0,12,0,12); knob.Position=UDim2.new(pct,-6,0.5,-6)
                knob.BackgroundColor3=C.Text; knob.BorderSizePixel=0
                Instance.new("UICorner", knob)
                RefColor("Text", knob, "BackgroundColor3")

                local function updateSliderVisuals(newPct, newVal)
                    Tween(fill, {Size = UDim2.new(newPct,0,1,0)}, 0.15)
                    Tween(knob, {Position = UDim2.new(newPct,-6,0.5,-6)}, 0.15)
                    v.Text = string.format("%.2f", newVal)
                    if cb then cb(newVal) end
                end

                v.FocusLost:Connect(function()
                    local num = tonumber(v.Text)
                    if num then
                        val = math.clamp(num, minV, maxV)
                        local p2 = (val-minV)/(maxV-minV)
                        updateSliderVisuals(p2, val)
                    else
                        v.Text = string.format("%.2f", val)
                    end
                end)

                local slDrag = false
                local function updateDrag(input)
                    local p = math.clamp((input.Position.X - track.AbsolutePosition.X)/track.AbsoluteSize.X, 0, 1)
                    val = minV + (maxV-minV)*p
                    updateSliderVisuals(p, val)
                end

                trackArea.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                        slDrag=true; updateDrag(i) end end)
                UIS.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then slDrag=false end end)
                UIS.InputChanged:Connect(function(i)
                    if slDrag and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then updateDrag(i) end end)

                regEntry.getValue = function() return val end
                regEntry.setValue = function(newVal)
                    val = math.clamp(newVal, minV, maxV)
                    local p2 = (val-minV)/(maxV-minV)
                    updateSliderVisuals(p2, val)
                end
                table.insert(Registry.sliders, regEntry)
                return regEntry
            end

