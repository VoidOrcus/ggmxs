                local copyIcon = Instance.new("ImageLabel",copyBtn)
                copyIcon.Size = UDim2.new(0,12,0,12)
                copyIcon.Position = UDim2.new(0.5,-6,0.5,-6)
                copyIcon.BackgroundTransparency = 1
                copyIcon.Image = Icons.Copy
                copyIcon.ImageColor3 = C.TextSub
                copyIcon.ZIndex = 2
                RefColor("TextSub", copyIcon, "ImageColor3")

                copyBtn.MouseButton1Click:Connect(function()
                    pcall(function() setclipboard(HexBox.Text) end)
                end)

                local function UpdateColor()
                    local c=Color3.fromHSV(hue,sat,val)
                    SVBox.BackgroundColor3=Color3.fromHSV(hue,1,1)
                    Preview.BackgroundColor3=c
                    rBox.Text=tostring(math.floor(c.R*255))
                    gBox.Text=tostring(math.floor(c.G*255))
                    bBox.Text=tostring(math.floor(c.B*255))
                    HexBox.Text="#"..c:ToHex()
                    cursor.Position=UDim2.new(sat,-4,1-val,-4)
                    hCursor.Position=UDim2.new(0,-2,hue,-2)
                    if onChange then onChange(c) end
                end

                local function SetColor(c)
                    local h,s,v2 = c:ToHSV()
                    hue=h; sat=s; val=v2
                    UpdateColor()
                end

                regEntry.setColor = SetColor
                table.insert(Registry.colorpickers, regEntry)

                local svDrag,hDrag=false,false
                SVBox.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                        svDrag=true
                        sat=math.clamp((i.Position.X-SVBox.AbsolutePosition.X)/SVBox.AbsoluteSize.X,0,1)
                        val=1-math.clamp((i.Position.Y-SVBox.AbsolutePosition.Y)/SVBox.AbsoluteSize.Y,0,1)
                        UpdateColor()
                    end
                end)
                HueStrip.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                        hDrag=true
                        hue=math.clamp((i.Position.Y-HueStrip.AbsolutePosition.Y)/HueStrip.AbsoluteSize.Y,0,1)
                        UpdateColor()
                    end
                end)
                UIS.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                        svDrag=false; hDrag=false
                    end
                end)
                UIS.InputChanged:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch then
                        if svDrag then
                            sat=math.clamp((i.Position.X-SVBox.AbsolutePosition.X)/SVBox.AbsoluteSize.X,0,1)
                            val=1-math.clamp((i.Position.Y-SVBox.AbsolutePosition.Y)/SVBox.AbsoluteSize.Y,0,1)
                            UpdateColor()
                        elseif hDrag then
                            hue=math.clamp((i.Position.Y-HueStrip.AbsolutePosition.Y)/HueStrip.AbsoluteSize.Y,0,1)
                            UpdateColor()
                        end
                    end
                end)
            end

