-- STARRY BACKGROUND
-- ────────────────────────────────────────────────
local function CreateStarField(parent)
    local canvas = Create("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ZIndex = 0,
        Parent = parent,
    })
    math.randomseed(42)
    for i = 1, 80 do
        local x    = math.random(0, 1000) / 1000
        local y    = math.random(0, 1000) / 1000
        local sz   = math.random(1, 3)
        local alpha= math.random(30, 80) / 100
        local star = Create("Frame", {
            Size             = UDim2.new(0, sz, 0, sz),
            Position         = UDim2.new(x, 0, y, 0),
            BackgroundColor3 = Color3.fromRGB(200, 180, 255),
            BackgroundTransparency = alpha,
            ZIndex           = 1,
            Parent           = canvas,
        })
        AddCorner(star, 50)
        local delay = math.random(0, 300) / 100
        task.delay(delay, function()
            local function twinkle()
                if not star or not star.Parent then return end
                Tween(star, {BackgroundTransparency = math.random(20, 70) / 100},
                    TweenInfo.new(math.random(10, 30) / 10, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut))
                task.delay(math.random(10, 30) / 10, twinkle)
            end
            twinkle()
        end)
    end
    return canvas
end

-- ────────────────────────────────────────────────
-- DRAGGABLE
-- ────────────────────────────────────────────────
local function MakeDraggable(handle, target)
    local dragging = false
    local dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging  = true
            dragStart = input.Position
            startPos  = target.Position
        end
    end)
    handle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            target.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- ────────────────────────────────────────────────
-- HSV COLOR PICKER (igual à imagem: 2D SV + hue strip + hex + RGBA)
-- ────────────────────────────────────────────────
local function BuildColorPicker(parent)
    -- Dimensões do picker
    local PW, PH = 360, 320

    local pickerFrame = Create("Frame", {
        Size             = UDim2.new(0, PW, 0, PH),
        Position         = UDim2.new(0.5, -PW/2, 0.5, -PH/2),
        BackgroundColor3 = Color3.fromRGB(16, 14, 28),
        ZIndex           = 100,
        Visible          = false,
        Parent           = parent,
    })
    AddCorner(pickerFrame, 12)
    AddStroke(pickerFrame, ACCENT, 1)

    -- Título
    Create("TextLabel", {
        Size             = UDim2.new(1, -12, 0, 26),
        Position         = UDim2.new(0, 6, 0, 4),
        BackgroundTransparency = 1,
        Text             = "Color Picker",
        TextColor3       = TEXT_PRIMARY,
        Font             = Enum.Font.GothamBold,
        TextSize         = 13,
        TextXAlignment   = Enum.TextXAlignment.Left,
        ZIndex           = 101,
        Parent           = pickerFrame,
    })

    -- ── SV square area (área 2D: saturação X / value Y) ──
    local SV_X, SV_Y = 12, 34
    local SV_W, SV_H = 200, 200

    -- Fundo (hue puro)
    local svBase = Create("Frame", {
        Size             = UDim2.new(0, SV_W, 0, SV_H),
        Position         = UDim2.new(0, SV_X, 0, SV_Y),
        BackgroundColor3 = Color3.fromHSV(0, 1, 1),  -- começa em vermelho
        ZIndex           = 101,
        Parent           = pickerFrame,
    })
    AddCorner(svBase, 6)

    -- Overlay branco (left=white → right=transparent)
    local whiteOverlay = Create("Frame", {
        Size             = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        ZIndex           = 102,
        Parent           = svBase,
    })
    AddCorner(whiteOverlay, 6)
    Create("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255,255,255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(255,255,255)),
        }),
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0),
            NumberSequenceKeypoint.new(1, 1),
        }),
        Rotation = 0,
        Parent = whiteOverlay,
    })

    -- Overlay preto (top=transparent → bottom=black)
    local blackOverlay = Create("Frame", {
        Size             = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = Color3.fromRGB(0, 0, 0),
        ZIndex           = 103,
        Parent           = svBase,
    })
    AddCorner(blackOverlay, 6)
    Create("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(0,0,0)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(0,0,0)),
        }),
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 1),
            NumberSequenceKeypoint.new(1, 0),
        }),
        Rotation = 90,
        Parent = blackOverlay,
    })

    -- Cursor do SV
    local svCursor = Create("Frame", {
        Size        = UDim2.new(0, 14, 0, 14),
        Position    = UDim2.new(0, -7, 0, -7),
        AnchorPoint = Vector2.new(0, 0),
        BackgroundColor3 = Color3.fromRGB(255,255,255),
        ZIndex      = 104,
        Parent      = svBase,
    })
    AddCorner(svCursor, 7)
    AddStroke(svCursor, Color3.fromRGB(0,0,0), 2)

    -- ── Hue strip vertical ──
    local HUE_X = SV_X + SV_W + 10
    local hueStrip = Create("Frame", {
        Size             = UDim2.new(0, 18, 0, SV_H),
        Position         = UDim2.new(0, HUE_X, 0, SV_Y),
        BackgroundColor3 = Color3.fromRGB(255,0,0),
        ZIndex           = 101,
        Parent           = pickerFrame,
    })
    AddCorner(hueStrip, 5)
    Create("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0,     Color3.fromHSV(0,     1, 1)),
            ColorSequenceKeypoint.new(0.167, Color3.fromHSV(0.167, 1, 1)),
            ColorSequenceKeypoint.new(0.333, Color3.fromHSV(0.333, 1, 1)),
            ColorSequenceKeypoint.new(0.5,   Color3.fromHSV(0.5,   1, 1)),
            ColorSequenceKeypoint.new(0.667, Color3.fromHSV(0.667, 1, 1)),
            ColorSequenceKeypoint.new(0.833, Color3.fromHSV(0.833, 1, 1)),
            ColorSequenceKeypoint.new(1,     Color3.fromHSV(0,     1, 1)),
        }),
        Rotation = 90,
        Parent = hueStrip,
    })

    -- Cursor do hue
    local hueCursor = Create("Frame", {
        Size        = UDim2.new(1, 4, 0, 6),
        Position    = UDim2.new(0, -2, 0, -3),
        BackgroundColor3 = Color3.fromRGB(255,255,255),
        ZIndex      = 102,
        Parent      = hueStrip,
    })
    AddCorner(hueCursor, 3)
    AddStroke(hueCursor, Color3.fromRGB(0,0,0), 1)

    -- ── Preview de cor ──
    local PREV_X = HUE_X + 18 + 12
    local preview = Create("Frame", {
        Size             = UDim2.new(0, 66, 0, 66),
        Position         = UDim2.new(0, PREV_X, 0, SV_Y),
        BackgroundColor3 = ACCENT,
        ZIndex           = 101,
        Parent           = pickerFrame,
    })
    AddCorner(preview, 8)
    AddStroke(preview, BORDER, 1)

    -- ── Hex input ──
    local hexBox = Create("TextBox", {
        Size             = UDim2.new(0, 66, 0, 26),
        Position         = UDim2.new(0, PREV_X, 0, SV_Y + 70),
        BackgroundColor3 = BG_ITEM,
        Text             = "#8A2BE2",
        TextColor3       = TEXT_PRIMARY,
        Font             = Enum.Font.GothamSemibold,
        TextSize         = 10,
        PlaceholderText  = "#RRGGBB",
        PlaceholderColor3 = TEXT_MUTED,
        ZIndex           = 101,
        Parent           = pickerFrame,
    })
    AddCorner(hexBox, 5)
    AddStroke(hexBox, BORDER, 1)
    AddPadding(hexBox, 0, 0, 6, 6)

    -- ── R/G/B/A value inputs ──
    local channels = {
        {name="R", label="R", col=Color3.fromRGB(220,80,80),  def=138},
        {name="G", label="G", col=Color3.fromRGB(80,200,100), def=43},
        {name="B", label="B", col=Color3.fromRGB(80,140,240), def=226},
        {name="A", label="A", col=Color3.fromRGB(180,180,200),def=255},
    }

    local chanBoxes = {}
    for i, ch in ipairs(channels) do
        local yy = SV_Y + 100 + (i - 1) * 26
        Create("TextLabel", {
            Size             = UDim2.new(0, 12, 0, 20),
            Position         = UDim2.new(0, PREV_X, 0, yy),
            BackgroundTransparency = 1,
            Text             = ch.label,
            TextColor3       = ch.col,
            Font             = Enum.Font.GothamBold,
            TextSize         = 10,
            ZIndex           = 101,
            Parent           = pickerFrame,
        })
        local box = Create("TextBox", {
            Size             = UDim2.new(0, 50, 0, 20),
            Position         = UDim2.new(0, PREV_X + 14, 0, yy),
            BackgroundColor3 = BG_ITEM,
            Text             = tostring(ch.def),
            TextColor3       = TEXT_PRIMARY,
            Font             = Enum.Font.GothamSemibold,
            TextSize         = 10,
            ZIndex           = 101,
            Parent           = pickerFrame,
        })
        AddCorner(box, 4)
        AddStroke(box, BORDER, 1)
        AddPadding(box, 0, 0, 4, 4)
        chanBoxes[ch.name] = box
    end

    -- ── Estado interno ──
    local hue  = 0.75  -- ~purple
    local sat  = 0.81
    local val  = 0.89
    local alpha = 1.0
    local onChange = nil

    local function hsvToRgb255(h, s, v)
        local c = Color3.fromHSV(h, s, v)
        return math.floor(c.R*255), math.floor(c.G*255), math.floor(c.B*255)
    end

    local function updateAll()
        local color = Color3.fromHSV(hue, sat, val)
        preview.BackgroundColor3 = color
        svBase.BackgroundColor3  = Color3.fromHSV(hue, 1, 1)
        local r, g, b = hsvToRgb255(hue, sat, val)
        hexBox.Text = string.format("#%02X%02X%02X", r, g, b)
        chanBoxes["R"].Text = tostring(r)
        chanBoxes["G"].Text = tostring(g)
        chanBoxes["B"].Text = tostring(b)
        chanBoxes["A"].Text = tostring(math.floor(alpha * 255))
        -- cursor SV position
        svCursor.Position = UDim2.new(sat, -7, 1 - val, -7)
        -- cursor hue position
        hueCursor.Position = UDim2.new(0, -2, hue, -3)
        if onChange then onChange(color, math.floor(alpha * 255)) end
    end

    -- Drag no SV square
    local svDrag = false
    local svBtn = Create("TextButton", {
        Size             = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text             = "",
        ZIndex           = 105,
        Parent           = svBase,
    })
    svBtn.MouseButton1Down:Connect(function() svDrag = true end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then svDrag = false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if svDrag and (i.UserInputType == Enum.UserInputType.MouseMovement
            or i.UserInputType == Enum.UserInputType.Touch) then
            local rx = (i.Position.X - svBase.AbsolutePosition.X) / svBase.AbsoluteSize.X
            local ry = (i.Position.Y - svBase.AbsolutePosition.Y) / svBase.AbsoluteSize.Y
            sat = math.clamp(rx, 0, 1)
            val = math.clamp(1 - ry, 0, 1)
            updateAll()
        end
    end)

    -- Drag na hue strip
    local hueDrag = false
    local hueBtn = Create("TextButton", {
        Size             = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text             = "",
        ZIndex           = 103,
        Parent           = hueStrip,
    })
    hueBtn.MouseButton1Down:Connect(function() hueDrag = true end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then hueDrag = false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if hueDrag and (i.UserInputType == Enum.UserInputType.MouseMovement
            or i.UserInputType == Enum.UserInputType.Touch) then
            local ry = (i.Position.Y - hueStrip.AbsolutePosition.Y) / hueStrip.AbsoluteSize.Y
            hue = math.clamp(ry, 0, 0.9999)
            updateAll()
        end
    end)

    -- Hex input callback
    hexBox.FocusLost:Connect(function()
        local txt = hexBox.Text:gsub("#", ""):upper()
        if #txt == 6 then
            local r = tonumber(txt:sub(1,2), 16)
            local g = tonumber(txt:sub(3,4), 16)
            local b = tonumber(txt:sub(5,6), 16)
            if r and g and b then
                local h2, s2, v2 = Color3.fromRGB(r,g,b):ToHSV()
                hue = h2; sat = s2; val = v2
                updateAll()
            end
        end
    end)

    -- RGBA boxes callback
    local function onChanChange()
        local r = tonumber(chanBoxes["R"].Text) or 0
        local g = tonumber(chanBoxes["G"].Text) or 0
        local b = tonumber(chanBoxes["B"].Text) or 0
        local a = tonumber(chanBoxes["A"].Text) or 255
        r = math.clamp(r, 0, 255)
        g = math.clamp(g, 0, 255)
        b = math.clamp(b, 0, 255)
        a = math.clamp(a, 0, 255)
        alpha = a / 255
        local h2, s2, v2 = Color3.fromRGB(r,g,b):ToHSV()
        hue = h2; sat = s2; val = v2
        updateAll()
    end
    for _, box in pairs(chanBoxes) do
        box.FocusLost:Connect(onChanChange)
    end

    -- Botão fechar
    local closeBtn = Create("TextButton", {
        Size             = UDim2.new(1, -24, 0, 28),
        Position         = UDim2.new(0, 12, 1, -36),
        BackgroundColor3 = ACCENT_DARK,
        Text             = "Close",
        TextColor3       = TEXT_PRIMARY,
        Font             = Enum.Font.GothamBold,
        TextSize         = 12,
        ZIndex           = 101,
        Parent           = pickerFrame,
    })
    AddCorner(closeBtn, 6)
    HoverEffect(closeBtn, ACCENT_DARK, ACCENT)
    closeBtn.MouseButton1Click:Connect(function()
        Tween(pickerFrame, {Size = UDim2.new(0, PW, 0, 0)}, TWEEN_MED)
        task.delay(0.25, function()
            pickerFrame.Visible = false
            pickerFrame.Size = UDim2.new(0, PW, 0, PH)
        end)
    end)

    MakeDraggable(pickerFrame, pickerFrame)

    -- Inicializar visual
    updateAll()

    local picker = {}
    picker.Frame = pickerFrame

    function picker:Show(position, currentColor, callback)
        onChange = callback
        if currentColor then
            local h2, s2, v2 = currentColor:ToHSV()
            hue = h2; sat = s2; val = v2
        end
        if position then pickerFrame.Position = position end
        pickerFrame.Size = UDim2.new(0, PW, 0, 0)
        pickerFrame.Visible = true
        Tween(pickerFrame, {Size = UDim2.new(0, PW, 0, PH)}, TWEEN_SPRING)
        updateAll()
    end

    function picker:GetColor()
        return Color3.fromHSV(hue, sat, val), math.floor(alpha * 255)
    end

    return picker
end

