    local ProfilePic = Create("ImageLabel", { Parent = Sidebar, Size = UDim2.new(0, 40, 0, 40), Position = UDim2.new(0.5, -20, 0, 15), BackgroundColor3 = Theme.Element, Image = zZz.Icons.Logo, ZIndex = 3 })
    Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = ProfilePic })
    Create("UIStroke", { Color = Theme.Accent, Thickness = 1.5, Parent = ProfilePic })

    local TabContainer = Create("ScrollingFrame", { Parent = Sidebar, Size = UDim2.new(1, 0, 1, -80), Position = UDim2.new(0, 0, 0, 70), BackgroundTransparency = 1, ScrollBarThickness = 0, ZIndex = 3 })
    Create("UIListLayout", { Parent = TabContainer, HorizontalAlignment = Enum.HorizontalAlignment.Center, Padding = UDim.new(0, 12) })
    
    -- Indicador da aba ativa
