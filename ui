                        state = not state
                        if flagT then Library.Flags[flagT] = state end
                        Tween(track, {BackgroundColor3 = state and ACCENT or TOGGLE_OFF}, TWEEN_MED)
                        Tween(knob, {Position = state and UDim2.new(1,-21,0.5,-9) or UDim2.new(0,3,0.5,-9)}, TWEEN_MED)
                        if cfg.Callback then cfg.Callback(state, curC) end
                    end)
                    colorBox.MouseButton1Click:Connect(function()
                        local abs = colorBox.AbsolutePosition
                        local pos = UDim2.new(0, abs.X-180, 0, abs.Y-340)
                        Library._colorpicker:Show(pos, curC, function(c, a)
                            curC = c; colorBox.BackgroundColor3 = c
                            if flagC then Library.Flags[flagC] = c end
                            if cfg.ColorCallback then cfg.ColorCallback(c, a) end
                        end)
                    end)
                    MakeSep()
                    local CT = {}
                    function CT:SetToggle(v) state=v; Tween(track,{BackgroundColor3=state and ACCENT or TOGGLE_OFF},TWEEN_MED); Tween(knob,{Position=state and UDim2.new(1,-21,0.5,-9) or UDim2.new(0,3,0.5,-9)},TWEEN_MED); if flagT then Library.Flags[flagT]=state end end
                    function CT:SetColor(c) curC=c; colorBox.BackgroundColor3=c; if flagC then Library.Flags[flagC]=c end end
                    function CT:GetToggle() return state end
                    function CT:GetColor() return curC end
                    return CT
                end

                -- ── CHECKBOX ──
                function Sec:CreateCheckbox(cfg)
                    cfg = cfg or {}
                    local flagKey = cfg.Flag
                    local state   = cfg.Default or false
                    if flagKey then Library.Flags[flagKey] = state end
                    local row = MakeRow(36)
                    local box = Create("TextButton", {
                        Size             = UDim2.new(0, 20, 0, 20),
                        Position         = UDim2.new(0, 10, 0.5, -10),
                        BackgroundColor3 = state and ACCENT or BG_ITEM,
                        Text             = "",
                        ZIndex           = 6,
                        Parent           = row,
                    })
                    AddCorner(box, 5)
                    AddStroke(box, state and ACCENT or BORDER, 1)
                    local checkMark = Create("TextLabel", {
                        Size             = UDim2.new(1, 0, 1, 0),
                        BackgroundTransparency = 1,
                        Text             = "✓",
                        TextColor3       = Color3.fromRGB(255,255,255),
                        Font             = Enum.Font.GothamBold,
                        TextSize         = 13,
                        Visible          = state,
                        ZIndex           = 7,
                        Parent           = box,
                    })
                    Create("TextLabel", {
                        Size             = UDim2.new(1, -40, 0, 16),
                        Position         = UDim2.new(0, 38, 0.5, -8),
                        BackgroundTransparency = 1,
                        Text             = cfg.Name or "Checkbox",
                        TextColor3       = TEXT_PRIMARY,
                        Font             = Enum.Font.GothamSemibold,
                        TextSize         = 12,
                        TextXAlignment   = Enum.TextXAlignment.Left,
                        ZIndex           = 6,
                        Parent           = row,
                    })
                    box.MouseButton1Click:Connect(function()
                        state = not state
                        if flagKey then Library.Flags[flagKey] = state end
                        Tween(box, {BackgroundColor3 = state and ACCENT or BG_ITEM}, TWEEN_FAST)
                        checkMark.Visible = state
                        if cfg.Callback then cfg.Callback(state) end
                    end)
                    MakeSep()
                    local CB = {}
                    function CB:Set(v) state=v; box.BackgroundColor3=state and ACCENT or BG_ITEM; checkMark.Visible=state; if flagKey then Library.Flags[flagKey]=state end end
                    function CB:Get() return state end
                    return CB
                end

                -- ── LABEL ──
                function Sec:CreateLabel(cfg)
                    cfg = cfg or {}
                    local row = MakeRow(28)
                    Create("TextLabel", {
                        Size             = UDim2.new(1, -12, 1, 0),
                        Position         = UDim2.new(0, 10, 0, 0),
                        BackgroundTransparency = 1,
                        Text             = cfg.Text or "Label",
                        TextColor3       = cfg.Color or TEXT_SECONDARY,
                        Font             = cfg.Bold and Enum.Font.GothamBold or Enum.Font.Gotham,
                        TextSize         = cfg.Size or 11,
                        TextXAlignment   = Enum.TextXAlignment.Left,
                        ZIndex           = 6,
                        Parent           = row,
                    })
                    return row
                end

                return Sec
            end

            -- ── INFO CARDS (CONTENTS) com fundo roxo como na imagem ──
            function Tab:_AddInfoCards(col, cards)
                cards = cards or {}

                -- Card container com fundo destacado
                local container = Create("Frame", {
                    Size             = UDim2.new(1, -4, 0, 0),
                    AutomaticSize    = Enum.AutomaticSize.Y,
                    BackgroundColor3 = Color3.fromRGB(18, 14, 32),  -- roxo escuro
                    ZIndex           = 4,
                    Parent           = col,
                })
                AddCorner(container, 10)
                AddStroke(container, Color3.fromRGB(80, 40, 130), 1)
                Create("UIGradient", {
                    Color = ColorSequence.new({
                        ColorSequenceKeypoint.new(0, Color3.fromRGB(28, 18, 50)),
                        ColorSequenceKeypoint.new(1, Color3.fromRGB(18, 14, 34)),
                    }),
                    Rotation = 135,
                    Parent = container,
                })

                local inner = Create("Frame", {
                    Size             = UDim2.new(1, 0, 0, 0),
                    AutomaticSize    = Enum.AutomaticSize.Y,
                    BackgroundTransparency = 1,
                    ZIndex           = 5,
                    Parent           = container,
                })
                AddPadding(inner, 10, 10, 10, 10)
                AddListLayout(inner, Enum.FillDirection.Vertical, 8)

                -- Título "CONTENTS" em roxo
                Create("TextLabel", {
                    Size             = UDim2.new(1, 0, 0, 18),
                    BackgroundTransparency = 1,
                    Text             = "CONTENTS",
                    TextColor3       = ACCENT_LIGHT,
                    Font             = Enum.Font.GothamBlack,
                    TextSize         = 11,
                    TextXAlignment   = Enum.TextXAlignment.Left,
                    LayoutOrder      = 0,
                    ZIndex           = 6,
                    Parent           = inner,
                })

                -- Linha separadora
                Create("Frame", {
                    Size             = UDim2.new(1, 0, 0, 1),
                    BackgroundColor3 = Color3.fromRGB(80, 40, 130),
                    BackgroundTransparency = 0.4,
                    LayoutOrder      = 1,
                    ZIndex           = 6,
                    Parent           = inner,
                })

                -- Row de cards
                local cardsRow = Create("Frame", {
                    Size             = UDim2.new(1, 0, 0, 60),
                    BackgroundTransparency = 1,
                    LayoutOrder      = 2,
                    ZIndex           = 5,
                    Parent           = inner,
                })
                AddListLayout(cardsRow, Enum.FillDirection.Horizontal, 8,
                    Enum.HorizontalAlignment.Left, Enum.VerticalAlignment.Center)

                for _, card in ipairs(cards) do
                    local w = card.Width or 95
                    local c = Create("Frame", {
                        Size             = UDim2.new(0, w, 1, 0),
                        BackgroundColor3 = Color3.fromRGB(22, 18, 40),
                        ZIndex           = 6,
                        Parent           = cardsRow,
                    })
                    AddCorner(c, 8)
                    AddStroke(c, Color3.fromRGB(55, 30, 90), 1)

                    -- Ícone
                    Create("TextLabel", {
                        Size             = UDim2.new(1, 0, 0, 20),
                        Position         = UDim2.new(0, 0, 0.08, 0),
                        BackgroundTransparency = 1,
                        Text             = card.Icon or "⚡",
                        TextColor3       = ACCENT_LIGHT,
                        Font             = Enum.Font.GothamBold,
                        TextSize         = 15,
                        TextXAlignment   = Enum.TextXAlignment.Center,
                        ZIndex           = 7,
                        Parent           = c,
                    })
                    -- Label
                    Create("TextLabel", {
                        Size             = UDim2.new(1, -4, 0, 12),
                        Position         = UDim2.new(0, 2, 0.55, 0),
                        BackgroundTransparency = 1,
                        Text             = card.Label or "Value",
                        TextColor3       = TEXT_MUTED,
                        Font             = Enum.Font.Gotham,
                        TextSize         = 9,
                        TextXAlignment   = Enum.TextXAlignment.Center,
                        ZIndex           = 7,
                        Parent           = c,
                    })
                    -- Valor (em roxo/accent como na imagem)
                    local valueLabel = Create("TextLabel", {
                        Size             = UDim2.new(1, -4, 0, 16),
                        Position         = UDim2.new(0, 2, 0.73, 0),
                        BackgroundTransparency = 1,
                        Text             = tostring(card.Value or "—"),
                        TextColor3       = card.ValueColor or ACCENT_LIGHT,
                        Font             = Enum.Font.GothamBold,
                        TextSize         = 12,
                        TextXAlignment   = Enum.TextXAlignment.Center,
                        ZIndex           = 7,
                        Parent           = c,
                    })
                    card._valueLabel = valueLabel
                end

                return container
            end

            -- ── PUBLIC AddSection ──
            function Tab:AddSection(secConfig)
                secConfig = secConfig or {}
                local col = (secConfig.Column == "Right") and RightCol or LeftCol
                return self:_AddSectionToCol(col, secConfig)
            end

            function Tab:AddInfoCards(cards, column)
                local col = (column == "Right") and RightCol or LeftCol
                return self:_AddInfoCards(col, cards)
            end

            return Tab
        end

        return Cat
    end

    -- ── SAVE / LOAD CONFIG ──
    function Win:SaveConfig()
        local data = {}
        for k, v in pairs(Library.Flags) do
            local t = type(v)
            if t == "boolean" or t == "number" or t == "string" then
                data[k] = v
            elseif t == "userdata" then
                local ok2, _ = pcall(function() return v.R end)
                if ok2 then data[k] = {__type="Color3", r=v.R, g=v.G, b=v.B} end
                local ok3, _ = pcall(function() return v.Name end)
                if ok3 and not ok2 then data[k] = {__type="Enum", name=v.Name} end
            end
        end
        local json = HttpService:JSONEncode(data)
        return pcall(writefile, Library.ConfigPath, json)
    end

    function Win:LoadConfig()
        local ok2, raw = pcall(readfile, Library.ConfigPath)
        if not ok2 or not raw then return false end
        local ok3, data = pcall(function() return HttpService:JSONDecode(raw) end)
        if not ok3 then return false end
        for k, v in pairs(data) do
            if type(v) == "table" then
                if v.__type == "Color3" then
                    Library.Flags[k] = Color3.new(v.r, v.g, v.b)
                elseif v.__type == "Enum" then
                    local ok4, ev = pcall(function() return Enum.KeyCode[v.name] end)
                    if ok4 then Library.Flags[k] = ev end
                end
            else
                Library.Flags[k] = v
            end
        end
        return true
    end

    function Win:GetFlag(key) return Library.Flags[key] end

    function Win:Destroy()
        if ScreenGui and ScreenGui.Parent then ScreenGui:Destroy() end
    end

    return Win
end

