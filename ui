    local tbBg = Create("Frame", { Parent = ConfigTab.Page, Size = UDim2.new(1, 0, 0, 35), BackgroundColor3 = zZz.Theme.MainBg })
    Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = tbBg })
    Create("UIStroke", { Color = zZz.Theme.Border, Thickness = 1, Parent = tbBg })
    local TB = Create("TextBox", {
        Parent = tbBg, Size = UDim2.fromScale(1,1), BackgroundTransparency = 1,
        Text = configName, TextColor3 = zZz.Theme.Text, Font = Enum.Font.Gotham, TextSize = 13,
        PlaceholderText = "Config Name..."
    })
    TB.FocusLost:Connect(function() configName = TB.Text end)

    ConfigTab:CreateButton("💾 Save Config", function()
        WindowObj.SaveConfig(configName)
    end)
    ConfigTab:CreateButton("📂 Load Config", function()
        WindowObj.LoadConfig(configName)
    end)

    return WindowObj
end

return zZz
