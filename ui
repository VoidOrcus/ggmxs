            -- ══════════════════════════════════════════════════
            -- ── DROPDOWN (CORRIGIDO) ──
            -- ══════════════════════════════════════════════════
            function subObj:CreateDropdown(title, desc, options, default, cb)
                local selected = default or options[1]
                local isOpen   = false
                local ITEM_H   = 28
                local PADDING  = 6
                local totalOptH = #options * (ITEM_H + 3) + PADDING * 2
                local CLOSED_H = 52

                -- Frame externo com organização automática
                local f = Instance.new("Frame")
                f.Size = UDim2.new(1, 0, 0, CLOSED_H)
                f.BackgroundColor3 = C.Card
                f.BorderSizePixel = 0
                f.ClipsDescendants = false
                f.ZIndex = 10
                Instance.new("UICorner", f).CornerRadius = UDim.new(0, 8)
                RefColor("Card", f, "BackgroundColor3")
                local ddStroke = Instance.new("UIStroke", f)
                ddStroke.Color = C.Primary; ddStroke.Transparency = 0.6; ddStroke.Thickness = 1
                RefColor("Primary", ddStroke, "Color")
                self:_registerSmartItem(f, "dropdown", 1)

                -- Título (ocupa toda a largura na parte superior)
                local tLbl = Instance.new("TextLabel", f)
                tLbl.Size = UDim2.new(1, -16, 0, 16)
                tLbl.Position = UDim2.new(0, 12, 0, 8)
                tLbl.BackgroundTransparency = 1; tLbl.Text = title
                tLbl.TextColor3 = C.Text; tLbl.Font = Enum.Font.GothamBold
                tLbl.TextSize = 12; tLbl.TextXAlignment = 0
                tLbl.ZIndex = 11
                RefColor("Text", tLbl, "TextColor3")

                -- Subtítulo (abaixo do título)
                local dLbl = Instance.new("TextLabel", f)
                dLbl.Size = UDim2.new(1, -16, 0, 11)
                dLbl.Position = UDim2.new(0, 12, 0, 26)
                dLbl.BackgroundTransparency = 1; dLbl.Text = desc
                dLbl.TextColor3 = C.TextSub; dLbl.Font = Enum.Font.Gotham
                dLbl.TextSize = 10; dLbl.TextXAlignment = 0
                dLbl.ZIndex = 11
                RefColor("TextSub", dLbl, "TextColor3")

                -- Botão selector (abaixo do texto, na parte inferior do card)
                local selBtn = Instance.new("TextButton", f)
                selBtn.Size = UDim2.new(1, -24, 0, 24)
                selBtn.Position = UDim2.new(0, 12, 1, -30)
                selBtn.BackgroundColor3 = C.Dark
                selBtn.Text = ""
                selBtn.AutoButtonColor = false
                selBtn.BorderSizePixel = 0
                selBtn.ZIndex = 11
                Instance.new("UICorner", selBtn).CornerRadius = UDim.new(0, 6)
                RefColor("Dark", selBtn, "BackgroundColor3")
                local selStroke = Instance.new("UIStroke", selBtn)
                selStroke.Color = C.Border; selStroke.Transparency = 0.3
                RefColor("Border", selStroke, "Color")

                local selLbl = Instance.new("TextLabel", selBtn)
                selLbl.Size = UDim2.new(1, -30, 1, 0)
                selLbl.Position = UDim2.new(0, 10, 0, 0)
                selLbl.BackgroundTransparency = 1
                selLbl.Text = selected
                selLbl.TextColor3 = C.Text; selLbl.Font = Enum.Font.GothamSemibold
                selLbl.TextSize = 11; selLbl.TextXAlignment = 0
                selLbl.ZIndex = 12
                RefColor("Text", selLbl, "TextColor3")

                local chevronImg = Instance.new("ImageLabel", selBtn)
                chevronImg.Size = UDim2.new(0, 14, 0, 14)
                chevronImg.Position = UDim2.new(1, -20, 0.5, -7)
                chevronImg.BackgroundTransparency = 1
                chevronImg.Image = Icons.ArrowDown
                chevronImg.ImageColor3 = C.Primary
                chevronImg.ScaleType = Enum.ScaleType.Fit
                chevronImg.ZIndex = 12
                RefColor("Primary", chevronImg, "ImageColor3")

                -- Container de opções (abre abaixo do selBtn)
                local optContainer = Instance.new("Frame", f)
                optContainer.Size = UDim2.new(1, -24, 0, 0)
                optContainer.Position = UDim2.new(0, 12, 1, -26)
                optContainer.BackgroundColor3 = C.Dark
                optContainer.BorderSizePixel = 0
                optContainer.Visible = false
                optContainer.ClipsDescendants = true
                optContainer.ZIndex = 50
                Instance.new("UICorner", optContainer).CornerRadius = UDim.new(0, 8)
                RefColor("Dark", optContainer, "BackgroundColor3")
                local ocS = Instance.new("UIStroke", optContainer)
                ocS.Color = C.Primary; ocS.Transparency = 0.4; ocS.Thickness = 1
                RefColor("Primary", ocS, "Color")

                local optScroll = Instance.new("ScrollingFrame", optContainer)
                optScroll.Size = UDim2.new(1, 0, 1, 0)
                optScroll.BackgroundTransparency = 1
                optScroll.ScrollBarThickness = 2
                optScroll.BorderSizePixel = 0

                local optLayout = Instance.new("UIListLayout", optScroll)
                optLayout.Padding = UDim.new(0, 3)
                optLayout.SortOrder = Enum.SortOrder.LayoutOrder
                local ocPad = Instance.new("UIPadding", optScroll)
                ocPad.PaddingTop = UDim.new(0, PADDING); ocPad.PaddingBottom = UDim.new(0, PADDING)
                ocPad.PaddingLeft = UDim.new(0, PADDING); ocPad.PaddingRight = UDim.new(0, PADDING)

                for _, opt in ipairs(options) do
                    local item = Instance.new("TextButton", optScroll)
                    item.Size = UDim2.new(1, 0, 0, ITEM_H)
                    item.BackgroundColor3 = opt == selected and Color3.fromRGB(35,25,55) or C.Dark
                    item.Text = ""; item.AutoButtonColor = false
                    item.BorderSizePixel = 0
                    item.ZIndex = 51
                    Instance.new("UICorner", item).CornerRadius = UDim.new(0, 5)

                    local dot = Instance.new("Frame", item)
                    dot.Size = UDim2.new(0, 6, 0, 6)
                    dot.Position = UDim2.new(0, 8, 0.5, -3)
                    dot.BackgroundColor3 = opt == selected and C.Primary or Color3.fromRGB(60,50,80)
                    dot.BorderSizePixel = 0
                    dot.ZIndex = 52
                    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

                    local optLbl = Instance.new("TextLabel", item)
                    optLbl.Size = UDim2.new(1, -22, 1, 0)
                    optLbl.Position = UDim2.new(0, 20, 0, 0)
                    optLbl.BackgroundTransparency = 1
                    optLbl.Text = opt
                    optLbl.TextColor3 = opt == selected and C.Text or C.TextSub
                    optLbl.Font = Enum.Font.GothamMedium
                    optLbl.TextSize = 10; optLbl.TextXAlignment = 0
                    optLbl.TextTruncate = Enum.TextTruncate.AtEnd
                    optLbl.ZIndex = 52

                    item.MouseEnter:Connect(function()
                        if opt ~= selected then Tween(item, {BackgroundColor3 = Color3.fromRGB(30,22,46)}, 0.1) end
                    end)
                    item.MouseLeave:Connect(function()
                        if opt ~= selected then Tween(item, {BackgroundColor3 = C.Dark}, 0.1) end
                    end)

                    item.MouseButton1Click:Connect(function()
                        selected = opt
                        selLbl.Text = opt
                        for _, c2 in ipairs(optScroll:GetChildren()) do
                            if c2:IsA("TextButton") then
                                local d2 = c2:FindFirstChildWhichIsA("Frame")
                                local l2 = c2:FindFirstChildWhichIsA("TextLabel")
                                if d2 then d2.BackgroundColor3 = Color3.fromRGB(60,50,80) end
                                if l2 then l2.TextColor3 = C.TextSub end
                                c2.BackgroundColor3 = C.Dark
                            end
                        end
                        dot.BackgroundColor3 = C.Primary
                        optLbl.TextColor3 = C.Text
                        item.BackgroundColor3 = Color3.fromRGB(35,25,55)
                        isOpen = false
                        Tween(chevronImg, {Rotation = 0}, 0.15)
                        Tween(optContainer, {Size = UDim2.new(1, -24, 0, 0)}, 0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
                        task.delay(0.2, function() optContainer.Visible = false end)
                        if cb then cb(opt) end
                    end)
                end

                optLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                    optScroll.CanvasSize = UDim2.new(0, 0, 0, optLayout.AbsoluteContentSize.Y + (PADDING*2))
                end)

                selBtn.MouseButton1Click:Connect(function()
                    isOpen = not isOpen
                    if isOpen then
                        optContainer.Visible = true
                        Tween(chevronImg, {Rotation = 180}, 0.2)
                        Tween(optContainer, {Size = UDim2.new(1, -24, 0, math.min(totalOptH, 150))}, 0.22, Enum.EasingStyle.Quint)
                    else
                        Tween(chevronImg, {Rotation = 0}, 0.15)
                        Tween(optContainer, {Size = UDim2.new(1, -24, 0, 0)}, 0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
                        task.delay(0.2, function() optContainer.Visible = false end)
                    end
                end)

                UIS.InputBegan:Connect(function(input)
                    if isOpen and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
                        local mPos = UIS:GetMouseLocation()
                        local fPos = selBtn.AbsolutePosition
                        local fSize = selBtn.AbsoluteSize
                        local optPos = optContainer.AbsolutePosition
                        local optSize = optContainer.AbsoluteSize

                        local inF = mPos.X >= fPos.X and mPos.X <= fPos.X + fSize.X and mPos.Y >= fPos.Y and mPos.Y <= fPos.Y + fSize.Y
                        local inOpt = mPos.X >= optPos.X and mPos.X <= optPos.X + optSize.X and mPos.Y >= optPos.Y and mPos.Y <= optPos.Y + optSize.Y

                        if not inF and not inOpt then
                            isOpen = false
                            Tween(chevronImg, {Rotation = 0}, 0.15)
                            Tween(optContainer, {Size = UDim2.new(1, -24, 0, 0)}, 0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
                            task.delay(0.2, function() optContainer.Visible = false end)
                        end
                    end
                end)

                return {
                    getValue = function() return selected end,
                    setValue = function(v)
                        selected = v; selLbl.Text = v
                        for _, c2 in ipairs(optScroll:GetChildren()) do
                            if c2:IsA("TextButton") then
                                local d2 = c2:FindFirstChildWhichIsA("Frame")
                                local l2 = c2:FindFirstChildWhichIsA("TextLabel")
                                if d2 and l2 then
                                    local isMatch = l2.Text == v
                                    d2.BackgroundColor3 = isMatch and C.Primary or Color3.fromRGB(60,50,80)
                                    l2.TextColor3 = isMatch and C.Text or C.TextSub
                                    c2.BackgroundColor3 = isMatch and Color3.fromRGB(35,25,55) or C.Dark
                                end
                            end
                        end
                    end,
                }
            end

            -- ── ANIMAÇÃO SEQUENTIAL SUB-TAB ──
            stBtn.MouseButton1Click:Connect(function()
                if self.ActiveSub == subObj then return end
                local EXIT_T, ENTER_T = 0.18, 0.22
                if self.ActiveSub then
                    Tween(self.ActiveSub.Btn,  {TextColor3=C.TextSub}, EXIT_T)
                    Tween(self.ActiveSub.Line, {BackgroundTransparency=1}, EXIT_T)
                end
                Tween(stBtn,  {TextColor3=C.Text}, EXIT_T)
                Tween(stLine, {BackgroundTransparency=0}, EXIT_T)
                if self.ActiveSub then
                    local old = self.ActiveSub.Content
                    self.ActiveSub = subObj
                    Tween(old, {GroupTransparency=1, Position=UDim2.new(-0.08,0,0,0)}, EXIT_T, Enum.EasingStyle.Sine)
                    task.delay(EXIT_T, function()
                        old.Visible=false; old.GroupTransparency=0; old.Position=UDim2.new(0,0,0,0)
                        ContentArea.Position=UDim2.new(0.08,0,0,0)
                        ContentArea.GroupTransparency=1; ContentArea.Visible=true
                        Tween(ContentArea, {GroupTransparency=0, Position=UDim2.new(0,0,0,0)}, ENTER_T, Enum.EasingStyle.Sine)
                    end)
                else
                    self.ActiveSub = subObj
                    ContentArea.Position=UDim2.new(0.08,0,0,0)
                    ContentArea.GroupTransparency=1; ContentArea.Visible=true
                    Tween(ContentArea, {GroupTransparency=0, Position=UDim2.new(0,0,0,0)}, ENTER_T, Enum.EasingStyle.Sine)
                end
            end)

            if #self.SubTabs == 1 then
                stBtn.TextColor3=C.Text; stLine.BackgroundTransparency=0
                ContentArea.GroupTransparency=0; ContentArea.Visible=true
                self.ActiveSub=subObj
            end
            return subObj
        end

        return TabData
    end


