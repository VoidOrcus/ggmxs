function zZz:CreateWindow(config)
    config = config or {}
    local title      = config.Name       or "zZzHub"
    local subtitle   = config.SubTitle   or "Premium Script Hub"
    local hideKey    = config.HideKey    or Enum.KeyCode.RightShift
    local configPath = config.ConfigPath or "zZzHub_config.json"
    local size       = config.Size       or UDim2.new(0, 880, 0, 580)

    Library.HideKey    = hideKey
    Library.ConfigPath = configPath

    local function SysHideGui(gui)
        pcall(function() game:GetService("StarterGui"):SetCore("TopbarEnabled", false) end)
        pcall(function()
            if syn and syn.protect_gui then syn.protect_gui(gui)
            elseif protect_gui then protect_gui(gui) end
        end)
    end

    -- ── ROOT SCREENGUI ──
    local ScreenGui = Create("ScreenGui", {
        Name           = "zZzHubUI",
        ResetOnSpawn   = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        IgnoreGuiInset = true,
    })
    local ok = pcall(function() ScreenGui.Parent = CoreGui end)
    if not ok then ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui") end
    SysHideGui(ScreenGui)
    Library._gui = ScreenGui

    -- ── MAIN FRAME ──
    local MainFrame = Create("Frame", {
        Name             = "MainFrame",
        Size             = size,
        Position         = UDim2.new(0.5, -(size.X.Offset/2), 0.5, -(size.Y.Offset/2)),
        BackgroundColor3 = BG_MAIN,
        ClipsDescendants = true,
        Parent           = ScreenGui,
    })
    AddCorner(MainFrame, 14)
    AddStroke(MainFrame, BORDER, 1)
    Create("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0,   Color3.fromRGB(12, 10, 22)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(10, 10, 20)),
            ColorSequenceKeypoint.new(1,   Color3.fromRGB(8,  12, 26)),
        }),
        Rotation = 125,
        Parent = MainFrame,
    })
