        function TabObj:CreateSlider(config)
            local name = config.Name or "Slider"
            local flag = config.Flag or name
            local min = config.Min or 0
            local max = config.Max or 100
            local default = config.Default or min
            local callback = config.Callback or function() end

            zZz.Flags[flag] = default

            local SldBg = Create("Frame", { Parent = Page, Size = UDim2.new(1, 0, 0, 50), BackgroundColor3 = zZz.Theme.ElementBg })
            Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = SldBg })
            Create("UIStroke", { Color = zZz.Theme.Border, Thickness = 1, Parent = SldBg })

            Create("TextLabel", {
                Parent = SldBg, Position = UDim2.new(0, 10, 0, 5), Size = UDim2.new(1, -60, 0, 15),
                BackgroundTransparency = 1, Text = name, TextColor3 = zZz.Theme.Text,
                Font = Enum.Font.GothamSemibold, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left
            })

            local ValueLbl = Create("TextLabel", {
                Parent = SldBg, Position = UDim2.new(1, -50, 0, 5), Size = UDim2.new(0, 40, 0, 15),
                BackgroundTransparency = 1, Text = tostring(default), TextColor3 = zZz.Theme.Accent,
                Font = Enum.Font.GothamBold, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Right
            })

            local Track = Create("Frame", {
                Parent = SldBg, Position = UDim2.new(0, 10, 0, 30), Size = UDim2.new(1, -20, 0, 8),
                BackgroundColor3 = zZz.Theme.MainBg
            })
            Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Track })
            local Fill = Create("Frame", { Parent = Track, Size = UDim2.new(0, 0, 1, 0), BackgroundColor3 = zZz.Theme.Accent })
            Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Fill })

            local function SetValue(val)
                val = math.clamp(val, min, max)
                zZz.Flags[flag] = val
                ValueLbl.Text = tostring(math.floor(val))
                Tween(Fill, {Size = UDim2.new((val - min) / (max - min), 0, 1, 0)}, 0.1)
                pcall(callback, val)
            end

            zZz.UpdateCallbacks[flag] = SetValue

            local dragging = false
            Track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    local pct = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                    SetValue(min + (max - min) * pct)
                end
            end)
            UIS.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
            end)
            UIS.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    local pct = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                    SetValue(min + (max - min) * pct)
                end
            end)
            SetValue(default)
        end

        function TabObj:CreateDropdown(config)
            local name = config.Name or "Dropdown"
            local flag = config.Flag or name
            local options = config.Options or {}
            local default = config.Default or options[1]
            local callback = config.Callback or function() end

            zZz.Flags[flag] = default

            local DropBg = Create("Frame", { Parent = Page, Size = UDim2.new(1, 0, 0, 35), BackgroundColor3 = zZz.Theme.ElementBg, ClipsDescendants = true })
            Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = DropBg })
            Create("UIStroke", { Color = zZz.Theme.Border, Thickness = 1, Parent = DropBg })

            local TopBtn = Create("TextButton", { Parent = DropBg, Size = UDim2.new(1,0,0,35), BackgroundTransparency = 1, Text = "" })
            Create("TextLabel", {
                Parent = TopBtn, Position = UDim2.new(0, 10, 0, 0), Size = UDim2.new(1, -60, 1, 0),
                BackgroundTransparency = 1, Text = name .. ": " .. tostring(default), TextColor3 = zZz.Theme.Text,
                Font = Enum.Font.GothamSemibold, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left
            })
            local Icon = Create("TextLabel", {
                Parent = TopBtn, Position = UDim2.new(1, -30, 0, 0), Size = UDim2.new(0, 20, 1, 0),
                BackgroundTransparency = 1, Text = "+", TextColor3 = zZz.Theme.Accent, Font = Enum.Font.GothamBold, TextSize = 18
            })

            local List = Create("ScrollingFrame", {
                Parent = DropBg, Position = UDim2.new(0, 0, 0, 35), Size = UDim2.new(1, 0, 1, -35),
                BackgroundTransparency = 1, ScrollBarThickness = 2, ScrollBarImageColor3 = zZz.Theme.Accent
            })
            Create("UIListLayout", { Parent = List, SortOrder = Enum.SortOrder.LayoutOrder })

            local isOpen = false
            local function ToggleDrop()
                isOpen = not isOpen
                Tween(DropBg, {Size = UDim2.new(1, 0, 0, isOpen and math.min(35 + (#options * 25), 135) or 35)})
                Icon.Text = isOpen and "-" or "+"
            end

            local function SetValue(val)
                zZz.Flags[flag] = val
                TopBtn:FindFirstChildOfClass("TextLabel").Text = name .. ": " .. tostring(val)
                pcall(callback, val)
                if isOpen then ToggleDrop() end
            end

            zZz.UpdateCallbacks[flag] = SetValue
            TopBtn.MouseButton1Click:Connect(ToggleDrop)

            for _, opt in ipairs(options) do
                local OptBtn = Create("TextButton", {
                    Parent = List, Size = UDim2.new(1, 0, 0, 25), BackgroundColor3 = zZz.Theme.ElementBg,
                    Text = tostring(opt), TextColor3 = zZz.Theme.TextDark, Font = Enum.Font.Gotham, TextSize = 12
                })
                OptBtn.MouseEnter:Connect(function() Tween(OptBtn, {BackgroundColor3 = zZz.Theme.Hover, TextColor3 = zZz.Theme.Accent}) end)
                OptBtn.MouseLeave:Connect(function() Tween(OptBtn, {BackgroundColor3 = zZz.Theme.ElementBg, TextColor3 = zZz.Theme.TextDark}) end)
                OptBtn.MouseButton1Click:Connect(function() SetValue(opt) end)
            end
            SetValue(default)
        end

        function TabObj:CreateColorPicker(config)
