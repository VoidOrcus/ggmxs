            nameBox.TextSize = 12
            nameBox.TextXAlignment = 0
            nameBox.ClearTextOnFocus = false
            RefColor("Text", nameBox, "TextColor3")
            RefColor("TextSub", nameBox, "PlaceholderColor3")

            local saveBtn = Instance.new("TextButton", SubCfgSave.Left)
            saveBtn.Size = UDim2.new(1, 0, 0, 36)
            saveBtn.BackgroundColor3 = C.Primary
            saveBtn.Text = ""
            saveBtn.TextColor3 = C.Text
            saveBtn.Font = Enum.Font.GothamBold
            saveBtn.TextSize = 13
            saveBtn.BorderSizePixel = 0
            Instance.new("UICorner", saveBtn).CornerRadius = UDim.new(0, 8)
            RefColor("Primary", saveBtn, "BackgroundColor3")

            local saveIcon = Instance.new("ImageLabel", saveBtn)
            saveIcon.Size = UDim2.new(0, 22, 0, 22)
            saveIcon.Position = UDim2.new(0.5, -11, 0.5, -11)
            saveIcon.BackgroundTransparency = 1
            saveIcon.Image = Icons.Save
            saveIcon.ScaleType = Enum.ScaleType.Fit
            saveIcon.ZIndex = 2

            local feedbackF = Instance.new("Frame", SubCfgSave.Left)
            feedbackF.Size = UDim2.new(1, 0, 0, 20)
            feedbackF.BackgroundTransparency = 1
            local feedbackLbl = Instance.new("TextLabel", feedbackF)
            feedbackLbl.Size = UDim2.new(1, 0, 1, 0)
            feedbackLbl.BackgroundTransparency = 1
            feedbackLbl.Text = ""
            feedbackLbl.TextColor3 = C.Accent
            feedbackLbl.Font = Enum.Font.GothamMedium
            feedbackLbl.TextSize = 11
            feedbackLbl.TextXAlignment = 0
            RefColor("Accent", feedbackLbl, "TextColor3")

            saveBtn.MouseButton1Click:Connect(function()
                local nm = nameBox.Text:match("^%s*(.-)%s*$")
                if nm == "" then
                    feedbackLbl.Text = "⚠  Enter a name first."
                    feedbackLbl.TextColor3 = Color3.fromRGB(230, 80, 80)
                else
                    DoSave(nm)
                    nameBox.Text = ""
                    feedbackLbl.Text = "✔  Saved: " .. nm
                    feedbackLbl.TextColor3 = C.Accent
                end
                task.delay(2.5, function() feedbackLbl.Text = "" end)
            end)
        end

        -- ── RIGHT: lista de saves ──
        do
            SubCfgSave._rightItems = SubCfgSave._rightItems + 1
            SubCfgSave._rebalance()

            local hdr2 = Instance.new("Frame", SubCfgSave.Right)
            hdr2.Size = UDim2.new(1, 0, 0, 22)
            hdr2.BackgroundTransparency = 1
            local h2Lbl = Instance.new("TextLabel", hdr2)
            h2Lbl.Size = UDim2.new(1, 0, 1, 0)
            h2Lbl.BackgroundTransparency = 1
            h2Lbl.Text = "SAVED CONFIGS"
            h2Lbl.TextColor3 = C.Primary
            h2Lbl.Font = Enum.Font.GothamBlack
            h2Lbl.TextSize = 11
            h2Lbl.TextXAlignment = 0
            RefColor("Primary", h2Lbl, "TextColor3")

            local listContainer = Instance.new("Frame", SubCfgSave.Right)
            listContainer.Size = UDim2.new(1, 0, 0, 1)
            listContainer.AutomaticSize = Enum.AutomaticSize.Y
            listContainer.BackgroundTransparency = 1
            local listLayout = Instance.new("UIListLayout", listContainer)
            listLayout.Padding = UDim.new(0, 6)
            listLayout.SortOrder = Enum.SortOrder.LayoutOrder

            local noSaves = Instance.new("Frame", listContainer)
            noSaves.Size = UDim2.new(1, 0, 0, 60)
            noSaves.BackgroundTransparency = 1
            local nsLbl = Instance.new("TextLabel", noSaves)
            nsLbl.Size = UDim2.new(1, 0, 1, 0)
            nsLbl.BackgroundTransparency = 1
            nsLbl.Text = "No saves yet.\nCreate one on the left."
            nsLbl.TextColor3 = C.TextSub
            nsLbl.Font = Enum.Font.Gotham
            nsLbl.TextSize = 11
            nsLbl.TextWrapped = true
            nsLbl.TextXAlignment = 0
            RefColor("TextSub", nsLbl, "TextColor3")
            NoSavesLabel = noSaves

            SavesListParent = listContainer
        end

        -- ═══════════════════════════════════════════════════════
        -- ── 9. CONFIG TAB: sub-tab COLORS ──
        -- (REMOVIDO Accent Color; mantidos apenas: Primary, TextSub, Border, BgMain, Header)
        -- ═══════════════════════════════════════════════════════

        local function MakeColorSectionLabel(parent, text, subData, side)
            if side == "left" then
                subData._leftItems = subData._leftItems + 1
            else
                subData._rightItems = subData._rightItems + 1
            end
            subData._rebalance()

            local f = Instance.new("Frame", parent)
            f.Size = UDim2.new(1, 0, 0, 22)
            f.BackgroundTransparency = 1
            local l = Instance.new("TextLabel", f)
            l.Size = UDim2.new(1, 0, 1, 0)
            l.BackgroundTransparency = 1
            l.Text = text
            l.TextColor3 = C.Primary
            l.Font = Enum.Font.GothamBlack
            l.TextSize = 11
            l.TextXAlignment = 0
            RefColor("Primary", l, "TextColor3")
        end

        MakeColorSectionLabel(SubCfgColors.Left,  "FIXED THEME",  SubCfgColors, "left")
        MakeColorSectionLabel(SubCfgColors.Right, "UI LOCKED",     SubCfgColors, "right")

        local fixedNotice = Instance.new("TextLabel", SubCfgColors.Left)
        fixedNotice.Size = UDim2.new(1, 0, 0, 44)
        fixedNotice.BackgroundTransparency = 1
        fixedNotice.Text = "Logo e cores da interface são fixas.\nUse ColorPicker apenas nos seus conteúdos, como ESP Fill."
        fixedNotice.TextColor3 = C.TextSub
        fixedNotice.Font = Enum.Font.GothamMedium
        fixedNotice.TextSize = 10
        fixedNotice.TextWrapped = true
        fixedNotice.TextXAlignment = Enum.TextXAlignment.Left
        fixedNotice.TextYAlignment = Enum.TextYAlignment.Top
        RefColor("TextSub", fixedNotice, "TextColor3")

        -- Esquerda: apenas Primary Color (removido Accent)
        -- Interface fixa: Primary Color removido/desativado.

        -- Direita: apenas MainBG, HeaderBG, Border/Lines, Subtitle
        do
            local ActivePopup = nil

            local function MakeCompactColorRow(parent, label, colorKey)
                SubCfgColors._rightItems = SubCfgColors._rightItems + 1
                SubCfgColors._rebalance()

                local row = Instance.new("Frame", parent)
                row.Size = UDim2.new(1, 0, 0, 44)
                row.BackgroundColor3 = C.Card
                row.BorderSizePixel = 0
                row.ClipsDescendants = false
                Instance.new("UICorner", row).CornerRadius = UDim.new(0, 7)
                RefColor("Card", row, "BackgroundColor3")
                local rS = Instance.new("UIStroke", row); rS.Color = C.Border; rS.Transparency = 0.4
                RefColor("Border", rS, "Color")

                local preview = Instance.new("Frame", row)
                preview.Size = UDim2.new(0, 26, 0, 26)
                preview.Position = UDim2.new(0, 9, 0.5, -13)
                preview.BackgroundColor3 = C[colorKey]
                preview.BorderSizePixel = 0
                Instance.new("UICorner", preview).CornerRadius = UDim.new(0, 5)
                RefColor(colorKey, preview, "BackgroundColor3")

                local lbl = Instance.new("TextLabel", row)
                lbl.Size = UDim2.new(1, -110, 1, 0)
                lbl.Position = UDim2.new(0, 44, 0, 0)
                lbl.BackgroundTransparency = 1
                lbl.Text = label
                lbl.TextColor3 = C.Text
                lbl.Font = Enum.Font.GothamSemibold
                lbl.TextSize = 11
                lbl.TextXAlignment = 0
                RefColor("Text", lbl, "TextColor3")

                local editBtn = Instance.new("TextButton", row)
                editBtn.Size = UDim2.new(0, 52, 0, 24)
                editBtn.Position = UDim2.new(1, -60, 0.5, -12)
                editBtn.BackgroundColor3 = Color3.fromRGB(162, 89, 255)
                editBtn.Text = "PICK"
                editBtn.TextColor3 = C.Text
                editBtn.Font = Enum.Font.GothamBold
                editBtn.TextSize = 10
                editBtn.BorderSizePixel = 0
                Instance.new("UICorner", editBtn).CornerRadius = UDim.new(0, 5)

                local popup = Instance.new("Frame", ScreenGui)
                popup.Size = UDim2.new(0, 220, 0, 240)
                popup.BackgroundColor3 = C.Dark
                popup.BorderSizePixel = 0
                popup.ClipsDescendants = false
                popup.Visible = false
                popup.ZIndex = 100
                Instance.new("UICorner", popup).CornerRadius = UDim.new(0, 10)
                RefColor("Dark", popup, "BackgroundColor3")
                local pS = Instance.new("UIStroke", popup); pS.Color = C.Primary; pS.Transparency = 0.3; pS.Thickness = 1
                RefColor("Primary", pS, "Color")

                local pTitle = Instance.new("TextLabel", popup)
                pTitle.Size = UDim2.new(1, -16, 0, 20)
                pTitle.Position = UDim2.new(0, 10, 0, 6)
                pTitle.BackgroundTransparency = 1
                pTitle.Text = label
                pTitle.TextColor3 = C.Text
                pTitle.Font = Enum.Font.GothamBold
                pTitle.TextSize = 11
                pTitle.TextXAlignment = 0
                pTitle.ZIndex = 101
                RefColor("Text", pTitle, "TextColor3")

                local closeBtn = Instance.new("TextButton", popup)
                closeBtn.Size = UDim2.new(0, 20, 0, 20)
                closeBtn.Position = UDim2.new(1, -26, 0, 6)
                closeBtn.BackgroundColor3 = Color3.fromRGB(190, 45, 65)
                closeBtn.Text = "✕"
                closeBtn.TextColor3 = C.Text
                closeBtn.Font = Enum.Font.GothamBold
                closeBtn.TextSize = 11
                closeBtn.BorderSizePixel = 0
                closeBtn.ZIndex = 102
                Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 5)

                local currentH, currentS, currentV = C[colorKey]:ToHSV()

                local SVBox = Instance.new("TextButton", popup)
                SVBox.Size = UDim2.new(0, 130, 0, 130)
                SVBox.Position = UDim2.new(0, 10, 0, 32)
                SVBox.BackgroundColor3 = Color3.fromHSV(currentH, 1, 1)
                SVBox.AutoButtonColor = false
                SVBox.Text = ""
                SVBox.BorderSizePixel = 0
                SVBox.ZIndex = 101
                Instance.new("UICorner", SVBox).CornerRadius = UDim.new(0, 7)

                local wOv = Instance.new("Frame", SVBox)
                wOv.Size = UDim2.fromScale(1,1); wOv.BackgroundColor3 = Color3.new(1,1,1); wOv.BorderSizePixel = 0; wOv.ZIndex = 102
                Instance.new("UICorner", wOv).CornerRadius = UDim.new(0, 7)
                local wGrad = Instance.new("UIGradient", wOv); wGrad.Transparency = NumberSequence.new(0,1); wGrad.Rotation = 0

                local bOv = Instance.new("Frame", SVBox)
                bOv.Size = UDim2.fromScale(1,1); bOv.BackgroundColor3 = Color3.new(0,0,0); bOv.BorderSizePixel = 0; bOv.ZIndex = 103
                Instance.new("UICorner", bOv).CornerRadius = UDim.new(0, 7)
                local bGrad = Instance.new("UIGradient", bOv); bGrad.Transparency = NumberSequence.new(1,0); bGrad.Rotation = 90

                local svCursor = Instance.new("Frame", SVBox)
                svCursor.Size = UDim2.new(0,10,0,10)
                svCursor.Position = UDim2.new(currentS,-5,1-currentV,-5)
                svCursor.BackgroundColor3 = Color3.new(1,1,1); svCursor.BorderSizePixel = 0; svCursor.ZIndex = 104
                Instance.new("UICorner", svCursor).CornerRadius = UDim.new(1,0)
                Instance.new("UIStroke", svCursor).Color = Color3.new(0,0,0)

                local HueStrip = Instance.new("TextButton", popup)
                HueStrip.Size = UDim2.new(0, 14, 0, 130)
                HueStrip.Position = UDim2.new(0, 148, 0, 32)
                HueStrip.BackgroundColor3 = Color3.new(1,1,1)
                HueStrip.AutoButtonColor = false
                HueStrip.Text = ""
                HueStrip.BorderSizePixel = 0
                HueStrip.ZIndex = 101
                Instance.new("UICorner", HueStrip).CornerRadius = UDim.new(0, 5)
                local hGrad2 = Instance.new("UIGradient", HueStrip); hGrad2.Rotation = 90
                hGrad2.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0,    Color3.fromHSV(0,1,1)),
                    ColorSequenceKeypoint.new(0.16, Color3.fromHSV(0.16,1,1)),
                    ColorSequenceKeypoint.new(0.33, Color3.fromHSV(0.33,1,1)),
                    ColorSequenceKeypoint.new(0.5,  Color3.fromHSV(0.5,1,1)),
                    ColorSequenceKeypoint.new(0.66, Color3.fromHSV(0.66,1,1)),
                    ColorSequenceKeypoint.new(0.83, Color3.fromHSV(0.83,1,1)),
                    ColorSequenceKeypoint.new(1,    Color3.fromHSV(1,1,1)),
                })

                local hCursor2 = Instance.new("Frame", HueStrip)
                hCursor2.Size = UDim2.new(1,4,0,5)
                hCursor2.Position = UDim2.new(0,-2,currentH,-2)
                hCursor2.BackgroundColor3 = Color3.new(1,1,1); hCursor2.BorderSizePixel = 0; hCursor2.ZIndex = 102
                Instance.new("UICorner", hCursor2).CornerRadius = UDim.new(0,2)
                Instance.new("UIStroke", hCursor2).Color = Color3.new(0,0,0)

                local prevRow = Instance.new("Frame", popup)
                prevRow.Size = UDim2.new(1,-20,0,28)
                prevRow.Position = UDim2.new(0,10,0,170)
                prevRow.BackgroundTransparency = 1
                prevRow.ZIndex = 101

                local prevBox = Instance.new("Frame", prevRow)
                prevBox.Size = UDim2.new(0,28,1,0)
                prevBox.BackgroundColor3 = C[colorKey]
                prevBox.BorderSizePixel = 0
                prevBox.ZIndex = 102
                Instance.new("UICorner", prevBox).CornerRadius = UDim.new(0,5)

                local hexBox = Instance.new("TextBox", prevRow)
                hexBox.Size = UDim2.new(1,-36,1,0)
                hexBox.Position = UDim2.new(0,36,0,0)
                hexBox.BackgroundColor3 = C.BgMain
                hexBox.TextColor3 = C.Text
                hexBox.Font = Enum.Font.GothamSemibold
                hexBox.TextSize = 10
                hexBox.Text = "#"..ColorToHex(C[colorKey])
                hexBox.BorderSizePixel = 0
                hexBox.ZIndex = 102
                Instance.new("UICorner", hexBox).CornerRadius = UDim.new(0,4)
                local hxS2 = Instance.new("UIStroke", hexBox); hxS2.Color = C.Border
                RefColor("BgMain", hexBox, "BackgroundColor3")
                RefColor("Text", hexBox, "TextColor3")
                RefColor("Border", hxS2, "Color")

                local copyBtnP = Instance.new("TextButton", hexBox)
                copyBtnP.Size = UDim2.new(0,28,1,0)
                copyBtnP.Position = UDim2.new(1,-28,0,0)
                copyBtnP.BackgroundTransparency = 1
                copyBtnP.Text = ""
                copyBtnP.ZIndex = 103

                local copyIconP = Instance.new("ImageLabel",copyBtnP)
                copyIconP.Size = UDim2.new(0,12,0,12)
                copyIconP.Position = UDim2.new(0.5,-6,0.5,-6)
                copyIconP.BackgroundTransparency = 1
                copyIconP.Image = Icons.Copy
                copyIconP.ImageColor3 = C.TextSub
                copyIconP.ZIndex = 104
                RefColor("TextSub",copyIconP,"ImageColor3")

                copyBtnP.MouseButton1Click:Connect(function()
                    pcall(function() setclipboard(hexBox.Text) end)
                end)

                local function MakeRGBLabel(parent, xOff, lStr, val)
                    local fr = Instance.new("Frame", parent)
                    fr.Size = UDim2.new(0,55,0,24)
                    fr.Position = UDim2.new(0,xOff,0,204)
                    fr.BackgroundColor3 = C.BgMain
                    fr.BorderSizePixel = 0
                    fr.ZIndex = 101
                    Instance.new("UICorner", fr).CornerRadius = UDim.new(0,5)
                    RefColor("BgMain", fr, "BackgroundColor3")
                    local ll = Instance.new("TextLabel", fr)
                    ll.Size = UDim2.new(0,14,1,0)
                    ll.BackgroundTransparency = 1
                    ll.Text = lStr
                    ll.TextColor3 = C.TextSub
                    ll.Font = Enum.Font.GothamBold
                    ll.TextSize = 9
                    ll.ZIndex = 102
                    RefColor("TextSub", ll, "TextColor3")
                    local vl = Instance.new("TextLabel", fr)
                    vl.Size = UDim2.new(1,-14,1,0)
                    vl.Position = UDim2.new(0,14,0,0)
                    vl.BackgroundTransparency = 1
                    vl.Text = tostring(val)
                    vl.TextColor3 = C.Text
                    vl.Font = Enum.Font.GothamMedium
                    vl.TextSize = 9
                    vl.ZIndex = 102
                    RefColor("Text", vl, "TextColor3")
                    return vl
                end
                local initR = math.floor(C[colorKey].R*255)
                local initG = math.floor(C[colorKey].G*255)
                local initB = math.floor(C[colorKey].B*255)
                local rLbl = MakeRGBLabel(popup, 10,  "R", initR)
                local gLbl = MakeRGBLabel(popup, 72,  "G", initG)
                local bLbl = MakeRGBLabel(popup, 134, "B", initB)

                local function UpdatePopupColor()
                    local c = Color3.fromHSV(currentH, currentS, currentV)
                    SVBox.BackgroundColor3 = Color3.fromHSV(currentH, 1, 1)
                    prevBox.BackgroundColor3 = c
                    preview.BackgroundColor3 = c
                    hexBox.Text = "#"..ColorToHex(c)
                    svCursor.Position = UDim2.new(currentS,-5,1-currentV,-5)
                    hCursor2.Position = UDim2.new(0,-2,currentH,-2)
                    rLbl.Text = tostring(math.floor(c.R*255))
                    gLbl.Text = tostring(math.floor(c.G*255))
                    bLbl.Text = tostring(math.floor(c.B*255))
                    SetPaletteColor(colorKey, c)
                end

                local cpReg = { id = NewRegId("cp"), paletteKey = colorKey }
                cpReg.setColor = function(c)
                    local h,s,v2 = c:ToHSV()
                    currentH=h; currentS=s; currentV=v2
                    UpdatePopupColor()
                end
                table.insert(Registry.colorpickers, cpReg)

                local function PositionPopup()
                    local btnPos = editBtn.AbsolutePosition
                    local px = btnPos.X - 230
                    local py = btnPos.Y - 100
                    local sw = ScreenGui.AbsoluteSize.X
                    local sh = ScreenGui.AbsoluteSize.Y
                    px = math.clamp(px, 5, sw - 225)
                    py = math.clamp(py, 5, sh - 245)
                    popup.Position = UDim2.new(0, px, 0, py)
                end

                local popOpen = false
                local svDrag2, hDrag2 = false, false

                editBtn.MouseButton1Click:Connect(function()
                    popOpen = not popOpen
                    if popOpen then
                        if ActivePopup and ActivePopup ~= popup then ActivePopup.Visible = false end
                        ActivePopup = popup
                        PositionPopup()
                        local h,s,v2 = C[colorKey]:ToHSV()
                        currentH=h; currentS=s; currentV=v2
                        UpdatePopupColor()
                        popup.Visible = true
                    else
                        popup.Visible = false
                        if ActivePopup == popup then ActivePopup = nil end
                    end
                end)

                closeBtn.MouseButton1Click:Connect(function()
                    popOpen = false
                    popup.Visible = false
                    if ActivePopup == popup then ActivePopup = nil end
                end)

                local popDragging, popDragStart, popStartPos
                pTitle.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                        popDragging=true; popDragStart=i.Position; popStartPos=popup.Position
                    end
                end)
                UIS.InputChanged:Connect(function(i)
                    if popDragging and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
                        local d = i.Position - popDragStart
                        popup.Position = UDim2.new(0, popStartPos.X.Offset+d.X, 0, popStartPos.Y.Offset+d.Y)
                    end
                end)
                UIS.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                        popDragging=false
                    end
                end)

                SVBox.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                        svDrag2=true
                        currentS=math.clamp((i.Position.X-SVBox.AbsolutePosition.X)/SVBox.AbsoluteSize.X,0,1)
                        currentV=1-math.clamp((i.Position.Y-SVBox.AbsolutePosition.Y)/SVBox.AbsoluteSize.Y,0,1)
                        UpdatePopupColor()
                    end
                end)
                HueStrip.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                        hDrag2=true
                        currentH=math.clamp((i.Position.Y-HueStrip.AbsolutePosition.Y)/HueStrip.AbsoluteSize.Y,0,1)
                        UpdatePopupColor()
                    end
                end)
                UIS.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                        svDrag2=false; hDrag2=false
                    end
                end)
                UIS.InputChanged:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch then
                        if svDrag2 then
                            currentS=math.clamp((i.Position.X-SVBox.AbsolutePosition.X)/SVBox.AbsoluteSize.X,0,1)
                            currentV=1-math.clamp((i.Position.Y-SVBox.AbsolutePosition.Y)/SVBox.AbsoluteSize.Y,0,1)
                            UpdatePopupColor()
                        elseif hDrag2 then
                            currentH=math.clamp((i.Position.Y-HueStrip.AbsolutePosition.Y)/HueStrip.AbsoluteSize.Y,0,1)
                            UpdatePopupColor()
                        end
                    end
                end)
            end

            -- Apenas 4 cores nas linhas compactas (removidos Card, Dark, Header)
            -- Interface fixa: linhas de cor da UI removidas/desativadas.
            -- MakeCompactColorRow(SubCfgColors.Right, "Subtitle Text",  "TextSub")
            -- MakeCompactColorRow(SubCfgColors.Right, "Border / Lines", "Border")
            -- MakeCompactColorRow(SubCfgColors.Right, "Main BG",        "BgMain")
            -- MakeCompactColorRow(SubCfgColors.Right, "Header BG",      "Header")
        end
        return TabConfig
    end

    -- Global keybind listener da janela
    UIS.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
        for _, reg in ipairs(Registry.toggles) do
            if reg.keybind and input.KeyCode == reg.keybind then
                reg.toggle()
            end
        end
    end)

    if options.DefaultConfigTab == true then
        Window:CreateCategory(options.ConfigCategory or "SETTINGS")
        Window:CreateDefaultConfigTab(options.ConfigTabOptions or {})
    end

    return Window
end

return zZzUILibrary
