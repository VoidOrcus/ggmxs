                local TglBg = Create("Frame", { Parent = SecCard, Size = UDim2.new(1, 0, 0, 36), BackgroundColor3 = Theme.Element })
                Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = TglBg }); Create("UIStroke", { Color = Theme.Border, Thickness = 1, Parent = TglBg })
                
                Create("TextLabel", { Parent = TglBg, Position = UDim2.new(0, 12, 0, 0), Size = UDim2.new(1, -80, 1, 0), BackgroundTransparency = 1, Text = name, TextColor3 = Theme.Text, Font = Fonts.Normal, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left })
                
                local SwitchBg = Create("Frame", { Parent = TglBg, Position = UDim2.new(1, -45, 0.5, -10), Size = UDim2.new(0, 36, 0, 20), BackgroundColor3 = Theme.BgBase })
                Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = SwitchBg }); Create("UIStroke", { Color = Theme.Border, Thickness = 1, Parent = SwitchBg })
                local Dot = Create("Frame", { Parent = SwitchBg, Position = UDim2.new(0, 2, 0.5, -8), Size = UDim2.new(0, 16, 0, 16), BackgroundColor3 = Theme.TextMuted })
                Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Dot })

                local Hitbox = Create("TextButton", { Parent = TglBg, Size = UDim2.new(hasColor and 0.8 or 1,0,1,0), BackgroundTransparency = 1, Text = "" })

                local function SetState(state)
                    zZz.Flags[flag] = state
                    Tween(SwitchBg, {BackgroundColor3 = state and Theme.Accent or Theme.BgBase})
                    Tween(Dot, {Position = UDim2.new(state and 1 or 0, state and -18 or 2, 0.5, -8), BackgroundColor3 = state and Color3.new(1,1,1) or Theme.TextMuted})
                    pcall(callback, state)
