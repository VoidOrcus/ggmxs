            subObj.Center = CenterCol

            local function RebalanceCols()
                local hasLeft  = subObj._leftItems  > 0
                local hasRight = subObj._rightItems > 0

                if hasLeft and hasRight then
                    LeftCol.Size      = UDim2.new(0.5, -5, 0, 0)
                    LeftCol.Position  = UDim2.new(0, 0, 0, 0)
                    RightCol.Size     = UDim2.new(0.5, -5, 0, 0)
                    RightCol.Position = UDim2.new(0.5, 5, 0, 0)
                    L_Lay.HorizontalAlignment = Enum.HorizontalAlignment.Left
                    R_Lay.HorizontalAlignment = Enum.HorizontalAlignment.Left
                elseif hasLeft then
                    -- ColorPicker sozinho não deve esticar até o conteúdo inteiro.
                    if subObj._onlyFixedHalfLeft then
                        LeftCol.Size      = UDim2.new(0.5, -5, 0, 0)
                        LeftCol.Position  = UDim2.new(0, 0, 0, 0)
                        L_Lay.HorizontalAlignment = Enum.HorizontalAlignment.Left
                    else
                        LeftCol.Size      = UDim2.new(1, 0, 0, 0)
                        LeftCol.Position  = UDim2.new(0, 0, 0, 0)
                        L_Lay.HorizontalAlignment = Enum.HorizontalAlignment.Center
                    end
                    RightCol.Size     = UDim2.new(0, 0, 0, 0)
                elseif hasRight then
                    -- ColorPicker sozinho não deve esticar até o conteúdo inteiro.
                    if subObj._onlyFixedHalfRight then
                        RightCol.Size     = UDim2.new(0.5, -5, 0, 0)
                        RightCol.Position = UDim2.new(0.5, 5, 0, 0)
                        R_Lay.HorizontalAlignment = Enum.HorizontalAlignment.Left
                    else
                        RightCol.Size     = UDim2.new(1, 0, 0, 0)
                        RightCol.Position = UDim2.new(0, 0, 0, 0)
                        R_Lay.HorizontalAlignment = Enum.HorizontalAlignment.Center
                    end
                    LeftCol.Size      = UDim2.new(0, 0, 0, 0)
                else
                    LeftCol.Size      = UDim2.new(0.5, -5, 0, 0)
                    LeftCol.Position  = UDim2.new(0, 0, 0, 0)
                    RightCol.Size     = UDim2.new(0.5, -5, 0, 0)
                    RightCol.Position = UDim2.new(0.5, 5, 0, 0)
                end
            end
            subObj._rebalance = RebalanceCols

            local function ResetSmartLayout()
                subObj._leftItems = 0
                subObj._rightItems = 0
                subObj._centerItems = 0
                subObj._leftWeight = 0
                subObj._rightWeight = 0
                subObj._onlyFixedHalfLeft = false
                subObj._onlyFixedHalfRight = false
                CenterCol.Visible = false
            end

            local function PutSmartItem(item, parent, layoutOrder)
                item.Frame.Parent = parent
                item.Frame.LayoutOrder = layoutOrder

                if parent == LeftCol then
                    subObj._leftItems = subObj._leftItems + 1
                    subObj._leftWeight = subObj._leftWeight + item.Weight
                    subObj._onlyFixedHalfLeft = (subObj._leftItems == 1 and item.FixedHalf == true)
                elseif parent == RightCol then
                    subObj._rightItems = subObj._rightItems + 1
                    subObj._rightWeight = subObj._rightWeight + item.Weight
                    subObj._onlyFixedHalfRight = (subObj._rightItems == 1 and item.FixedHalf == true)
                elseif parent == CenterCol then
                    subObj._centerItems = subObj._centerItems + 1
                    CenterCol.Visible = true
                end
            end

            function subObj:_applySmartLayout()
                ResetSmartLayout()

                local total = #self._smartItems
                if total <= 0 then
                    RebalanceCols()
                    UpdateCanvas()
                    return
                end

                local centerIndex = nil
                local lastItem = self._smartItems[total]

                -- Conta primeiro os itens fixos/preferidos.
                -- Isso deixa blocos grandes, como Statistics/Player Info, reservarem espaço antes
                -- dos toggles automáticos serem distribuídos. Exemplo:
                -- Player Info fixo na esquerda com peso 3 => até 3 toggles vão para a direita.
                local forcedLeftWeight = 0
                local forcedRightWeight = 0

                for _, item in ipairs(self._smartItems) do
                    if item.PreferredSide == "left" then
                        forcedLeftWeight = forcedLeftWeight + item.Weight
                    elseif item.PreferredSide == "right" then
                        forcedRightWeight = forcedRightWeight + item.Weight
                    end
                end

                -- Se o último item for normal e as colunas anteriores formarem um grid equilibrado,
                -- ele fica centralizado embaixo. Isso evita o visual de um item sobrando em uma coluna.
                if total >= 3 and lastItem and lastItem.PreferredSide ~= "left" and lastItem.PreferredSide ~= "right" and lastItem.Kind ~= "statistics" then
                    local testLeft = 0
                    local testRight = 0

                    -- Primeiro simula os itens fixos anteriores.
                    for i = 1, total - 1 do
                        local it = self._smartItems[i]
                        if it.PreferredSide == "left" then
                            testLeft = testLeft + it.Weight
                        elseif it.PreferredSide == "right" then
                            testRight = testRight + it.Weight
                        end
                    end

                    -- Depois distribui os automáticos usando os pesos fixos como base.
                    for i = 1, total - 1 do
                        local it = self._smartItems[i]
                        if it.PreferredSide ~= "left" and it.PreferredSide ~= "right" then
                            if testLeft <= testRight then
                                testLeft = testLeft + it.Weight
                            else
                                testRight = testRight + it.Weight
                            end
                        end
                    end

                    if math.abs(testLeft - testRight) <= 0.15 then
                        centerIndex = total
                    end
                end

                local virtualLeftWeight = forcedLeftWeight
                local virtualRightWeight = forcedRightWeight

                for i, item in ipairs(self._smartItems) do
                    if i == centerIndex then
                        PutSmartItem(item, CenterCol, i)
                    else
                        if item.PreferredSide == "left" then
                            PutSmartItem(item, LeftCol, i)
                        elseif item.PreferredSide == "right" then
                            PutSmartItem(item, RightCol, i)
                        else
                            if virtualLeftWeight <= virtualRightWeight then
                                PutSmartItem(item, LeftCol, i)
                                virtualLeftWeight = virtualLeftWeight + item.Weight
                            else
                                PutSmartItem(item, RightCol, i)
                                virtualRightWeight = virtualRightWeight + item.Weight
                            end
                        end
                    end
                end

                RebalanceCols()
                task.defer(UpdateCanvas)
            end

            function subObj:_registerSmartItem(frame, kind, weight, preferredSide)
                table.insert(self._smartItems, {
                    Frame = frame,
                    Kind = kind or "normal",
                    Weight = weight or 1,
                    PreferredSide = preferredSide,
                    FixedHalf = (kind == "colorpicker"),
