        Parent = Bubble, Size = UDim2.new(0, 30, 0, 30), Position = UDim2.new(0.5, -15, 0.5, -15),
        BackgroundTransparency = 1, Image = zZz.Icons.Logo, ImageColor3 = Theme.Accent
    })
    MakeDraggable(Bubble, Bubble)

    -- ── JANELA PRINCIPAL ──
