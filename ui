    local function SelectTab(btnObj, page, name, icon, desc)
        if currentTabBtn then
            Tween(currentTabBtn._indicator, {BackgroundTransparency = 1, Size = UDim2.new(0, 3, 0, 0)}, TWEEN_MED)
            Tween(currentTabBtn._bg, {BackgroundTransparency = 1}, TWEEN_MED)
            Tween(currentTabBtn._icon, {ImageColor3 = TEXT_MUTED}, TWEEN_MED)
            Tween(currentTabBtn._label, {TextColor3 = TEXT_SECONDARY}, TWEEN_MED)
        end
        if currentTabPage then currentTabPage.Visible = false end

        currentTabBtn  = btnObj
        currentTabPage = page
        Tween(btnObj._indicator, {BackgroundTransparency = 0, Size = UDim2.new(0, 3, 0, 34)}, TWEEN_SPRING)
        Tween(btnObj._bg, {BackgroundTransparency = 0.55}, TWEEN_MED)
        Tween(btnObj._icon, {ImageColor3 = ACCENT_LIGHT}, TWEEN_MED)
        Tween(btnObj._label, {TextColor3 = TEXT_PRIMARY}, TWEEN_MED)
        page.Visible = true
        TopTabName.Text = name
        TopTabDesc.Text = desc or ""
        TopIcon.Image   = icon or ICONS.default
    end

