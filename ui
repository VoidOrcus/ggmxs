    if CoreGui:FindFirstChild("zZz_StarryHub") then CoreGui.zZz_StarryHub:Destroy() end

    local ScreenGui = Create("ScreenGui", { Name = "zZz_StarryHub", Parent = gethui and gethui() or CoreGui, ResetOnSpawn = false, DisplayOrder = 999 })

