    WindowObj.SaveConfig = function(name)
        if not name or name == "" then name = "Default" end
        pcall(function()
            local saveTbl = {}
            for k,v in pairs(zZz.Flags) do
                if typeof(v) == "Color3" then saveTbl[k] = {v.R, v.G, v.B, "IsColor3"}
                elseif typeof(v) == "EnumItem" then saveTbl[k] = {v.Name, "IsEnum"}
                else saveTbl[k] = v end
            end
            writefile(SaveFolder.."/"..name..".json", HttpService:JSONEncode(saveTbl))
        end)
    end

    WindowObj.LoadConfig = function(name)
        local path = SaveFolder.."/"..name..".json"
        if isfile(path) then
            pcall(function()
                local data = HttpService:JSONDecode(readfile(path))
                for k, v in pairs(data) do
                    local finalVal = v
                    if type(v) == "table" then
                        if v[4] == "IsColor3" then finalVal = Color3.new(v[1], v[2], v[3])
                        elseif v[2] == "IsEnum" then finalVal = Enum.KeyCode[v[1]] end
                    end
                    if zZz.UpdateCallbacks[k] then zZz.UpdateCallbacks[k](finalVal) end
                end
            end)
        end
    end

