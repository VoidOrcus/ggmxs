            LeftCol.AutomaticSize = Enum.AutomaticSize.Y
            LeftCol.BackgroundTransparency = 1
        
            local L_Lay = Instance.new("UIListLayout", LeftCol)
            L_Lay.Padding = UDim.new(0, 8); L_Lay.SortOrder = Enum.SortOrder.LayoutOrder
            local L_Pad = Instance.new("UIPadding", LeftCol)
