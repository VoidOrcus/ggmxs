    Create("UIGradient", { Color = ColorSequence.new{ColorSequenceKeypoint.new(0, Color3.fromRGB(15, 10, 25)), ColorSequenceKeypoint.new(1, Theme.BgBase)}, Rotation = 45, Parent = Main })

