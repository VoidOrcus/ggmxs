                kbBtn.BorderSizePixel = 0
                Instance.new("UICorner", kbBtn).CornerRadius = UDim.new(0, 4)
                local kbStroke = Instance.new("UIStroke", kbBtn)
                kbStroke.Color = C.Border; kbStroke.Transparency = 0.4
                RefColor("Dark", kbBtn, "BackgroundColor3")
                RefColor("TextSub", kbBtn, "TextColor3")
                RefColor("Border", kbStroke, "Color")

                local TOGGLE_ON_COLOR = Color3.fromRGB(162, 89, 255)

                local function ApplyState(v, animated)
                    state = v
                    if animated then
                        Tween(track, {BackgroundColor3 = state and TOGGLE_ON_COLOR or Color3.fromRGB(50,40,60)}, 0.2)
                        Tween(knob,  {Position = state and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7)}, 0.2)
                        Tween(stroke,{Transparency = state and 0.3 or 0.7}, 0.2)
                    else
                        track.BackgroundColor3 = state and TOGGLE_ON_COLOR or Color3.fromRGB(50,40,60)
                        knob.Position = state and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7)
                        stroke.Transparency = state and 0.3 or 0.7
                    end
                    if cb then cb(state) end
                end

                f.MouseButton1Click:Connect(function() ApplyState(not state, true) end)

                kbBtn.MouseButton1Click:Connect(function()
                    if regEntry.keybind then
                        regEntry.keybind = nil
                        kbBtn.Text = "[KEY]"
                        kbBtn.TextColor3 = C.TextSub
                    else
                        kbBtn.Text = "..."
                        kbBtn.TextColor3 = C.Primary
                        local conn; conn = UIS.InputBegan:Connect(function(input, gpe)
                            if gpe then return end
                            if input.UserInputType == Enum.UserInputType.Keyboard then
                                conn:Disconnect()
                                regEntry.keybind = input.KeyCode
                                local kName = tostring(input.KeyCode):gsub("Enum.KeyCode.", "")
                                kbBtn.Text = kName
                                kbBtn.TextColor3 = C.Accent
                            end
                        end)
                    end
                end)

                regEntry.getState  = function() return state end
                regEntry.setState  = function(v) ApplyState(v, false) end
                regEntry.toggle    = function() ApplyState(not state, true) end
                regEntry.getKeybind = function()
                    if regEntry.keybind then
                        return tostring(regEntry.keybind):gsub("Enum.KeyCode.", "")
                    end
                    return nil
                end
                regEntry.setKeybind = function(kName)
                    if kName then
                        local ok, kc = pcall(function() return Enum.KeyCode[kName] end)
                        if ok and kc then
                            regEntry.keybind = kc
                            kbBtn.Text = kName
                            kbBtn.TextColor3 = C.Accent
                        end
                    else
                        regEntry.keybind = nil
                        kbBtn.Text = "[KEY]"
                        kbBtn.TextColor3 = C.TextSub
                    end
                end
                table.insert(Registry.toggles, regEntry)
            end

