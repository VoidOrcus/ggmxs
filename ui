        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(22, 22, 40)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(14, 14, 28)),
        }),
        Rotation = 135,
        Parent = pickerFrame,
    })

    -- Title
    Create("TextLabel", {
        Size = UDim2.new(1, -10, 0, 28),
        Position = UDim2.new(0, 5, 0, 4),
        BackgroundTransparency = 1,
        Text = "Color Picker",
        TextColor3 = TEXT_PRIMARY,
        Font = Enum.Font.GothamBold,
        TextSize = 13,
        ZIndex = 101,
        Parent = pickerFrame,
    })

    -- Preview box
    local preview = Create("Frame", {
        Size = UDim2.new(0, 44, 0, 44),
        Position = UDim2.new(0.5, -22, 0, 34),
        BackgroundColor3 = ACCENT,
        ZIndex = 101,
        Parent = pickerFrame,
    })
    AddCorner(preview, 8)
    AddStroke(preview, BORDER, 1)

    -- Hex label
    local hexLabel = Create("TextLabel", {
        Size = UDim2.new(1, -10, 0, 18),
        Position = UDim2.new(0, 5, 0, 83),
        BackgroundTransparency = 1,
        Text = "#8A2BE2",
        TextColor3 = TEXT_SECONDARY,
        Font = Enum.Font.GothamSemibold,
        TextSize = 10,
        TextXAlignment = Enum.TextXAlignment.Center,
        ZIndex = 101,
        Parent = pickerFrame,
    })

    local channels = {
        {name="R", label="R", default=138, color=Color3.fromRGB(220, 80, 80)},
        {name="G", label="G", default=43,  color=Color3.fromRGB(80, 200, 100)},
        {name="B", label="B", default=226, color=Color3.fromRGB(80, 140, 240)},
        {name="A", label="A", default=255, color=Color3.fromRGB(180, 180, 200)},
    }

    local sliderValues = {R=138, G=43, B=226, A=255}
    local sliderObjects = {}
    local onChange = nil

    local function updatePreview()
        local c = Color3.fromRGB(sliderValues.R, sliderValues.G, sliderValues.B)
        preview.BackgroundColor3 = c
        hexLabel.Text = string.format("#%02X%02X%02X", sliderValues.R, sliderValues.G, sliderValues.B)
        if onChange then onChange(c, sliderValues.A) end
    end

    for i, ch in ipairs(channels) do
        local yOff = 105 + (i - 1) * 36
        Create("TextLabel", {
            Size = UDim2.new(0, 14, 0, 14),
            Position = UDim2.new(0, 10, 0, yOff),
            BackgroundTransparency = 1,
            Text = ch.label,
            TextColor3 = ch.color,
            Font = Enum.Font.GothamBold,
            TextSize = 11,
            ZIndex = 101,
            Parent = pickerFrame,
        })

        local track = Create("Frame", {
            Size = UDim2.new(1, -60, 0, 6),
            Position = UDim2.new(0, 28, 0, yOff + 4),
            BackgroundColor3 = BG_ITEM,
            ZIndex = 101,
            Parent = pickerFrame,
        })
        AddCorner(track, 3)
        AddStroke(track, BORDER, 1)

        local fill = Create("Frame", {
            Size = UDim2.new(ch.default / 255, 0, 1, 0),
            BackgroundColor3 = ch.color,
            ZIndex = 102,
            Parent = track,
        })
        AddCorner(fill, 3)

        local knob = Create("Frame", {
            Size = UDim2.new(0, 12, 0, 12),
            Position = UDim2.new(ch.default / 255, -6, 0.5, -6),
            BackgroundColor3 = Color3.fromRGB(255, 255, 255),
            ZIndex = 103,
            Parent = track,
        })
        AddCorner(knob, 6)

        local valLabel = Create("TextLabel", {
            Size = UDim2.new(0, 28, 0, 14),
            Position = UDim2.new(1, -30, 0, yOff),
            BackgroundTransparency = 1,
            Text = tostring(ch.default),
            TextColor3 = TEXT_SECONDARY,
            Font = Enum.Font.Gotham,
            TextSize = 10,
            TextXAlignment = Enum.TextXAlignment.Right,
            ZIndex = 101,
            Parent = pickerFrame,
        })

        sliderObjects[ch.name] = {fill = fill, knob = knob, valLabel = valLabel}

        local draggingSlider = false
        track.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                draggingSlider = true
            end
        end)
        track.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                draggingSlider = false
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if draggingSlider and (
                input.UserInputType == Enum.UserInputType.MouseMovement
                or input.UserInputType == Enum.UserInputType.Touch) then
                local rel = (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
                rel = math.clamp(rel, 0, 1)
                local val = math.floor(rel * 255)
                sliderValues[ch.name] = val
                fill.Size = UDim2.new(rel, 0, 1, 0)
                knob.Position = UDim2.new(rel, -6, 0.5, -6)
                valLabel.Text = tostring(val)
                updatePreview()
            end
        end)
    end

    -- Close button
    local closeBtn = Create("TextButton", {
        Size = UDim2.new(1, -20, 0, 26),
        Position = UDim2.new(0, 10, 1, -34),
        BackgroundColor3 = ACCENT_DARK,
        Text = "Close",
        TextColor3 = TEXT_PRIMARY,
        Font = Enum.Font.GothamBold,
        TextSize = 11,
        ZIndex = 101,
        Parent = pickerFrame,
    })
    AddCorner(closeBtn, 6)
    closeBtn.MouseButton1Click:Connect(function()
        Tween(pickerFrame, {Size = UDim2.new(0, 220, 0, 0)}, TWEEN_MED)
        task.delay(0.25, function()
            pickerFrame.Visible = false
            pickerFrame.Size = UDim2.new(0, 220, 0, 260)
        end)
    end)

    MakeDraggable(pickerFrame, pickerFrame)

    local picker = {}
    picker.Frame = pickerFrame

    function picker:Show(position, currentColor, callback)
        onChange = callback
        if currentColor then
            sliderValues.R = math.floor(currentColor.R * 255)
            sliderValues.G = math.floor(currentColor.G * 255)
            sliderValues.B = math.floor(currentColor.B * 255)
            for _, ch in ipairs(channels) do
                local val = sliderValues[ch.name]
                local rel = val / 255
                local so = sliderObjects[ch.name]
                so.fill.Size = UDim2.new(rel, 0, 1, 0)
                so.knob.Position = UDim2.new(rel, -6, 0.5, -6)
                so.valLabel.Text = tostring(val)
            end
            updatePreview()
        end
        if position then
            pickerFrame.Position = position
        end
        pickerFrame.Size = UDim2.new(0, 220, 0, 0)
        pickerFrame.Visible = true
        Tween(pickerFrame, {Size = UDim2.new(0, 220, 0, 260)}, TWEEN_SPRING)
    end

    function picker:GetColor()
        return Color3.fromRGB(sliderValues.R, sliderValues.G, sliderValues.B), sliderValues.A
    end

    return picker
end

