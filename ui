    function Window:CreateTab(optionsOrName, iconId, desc)
        local name
        local icon
        local description

        if type(optionsOrName) == "table" then
            name = optionsOrName.Name or optionsOrName.Title or "Tab"
            icon = optionsOrName.Icon or Icons[optionsOrName.IconName or ""] or Icons.Misc
            description = optionsOrName.Description or optionsOrName.Desc
        else
            name = optionsOrName or "Tab"
            icon = iconId or Icons.Misc
            description = desc
        end

        return CreateTab(name, icon, description)
    end

