        function TabObj:CreateToggle(config)
            local name = config.Name or "Toggle"
            local flag = config.Flag or name
            local default = config.Default or false
            local callback = config.Callback or function() end
            
            zZz.Flags[flag] = default

            local TglBg = Create("Frame", { Parent = Page, Size = UDim2.new(1, 0, 0, 40), BackgroundColor3 = Theme.ElementBg })
            Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = TglBg })
            Create("UIStroke", { Color = Theme.Border, Thickness = 1, Parent = TglBg })
            
            Create("TextLabel", {
                Parent = TglBg, Position = UDim2.new(0, 15, 0, 0), Size = UDim2.new(1, -80, 1, 0), BackgroundTransparency = 1,
                Text = name, TextColor3 = Theme.Text, Font = Fonts.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left
            })

            local SwitchBg = Create("Frame", { Parent = TglBg, Position = UDim2.new(1, -50, 0.5, -10), Size = UDim2.new(0, 38, 0, 20), BackgroundColor3 = Theme.Background })
            Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = SwitchBg })
            Create("UIStroke", { Color = Theme.Border, Thickness = 1, Parent = SwitchBg })
            
            local Dot = Create("Frame", { Parent = SwitchBg, Position = UDim2.new(0, 2, 0.5, -7), Size = UDim2.new(0, 14, 0, 14), BackgroundColor3 = Theme.TextMuted })
            Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Dot })

            local Hitbox = Create("TextButton", { Parent = TglBg, Size = UDim2.fromScale(1,1), BackgroundTransparency = 1, Text = "" })

            local function SetState(state)
                zZz.Flags[flag] = state
                Tween(SwitchBg, {BackgroundColor3 = state and Theme.Accent or Theme.Background})
                Tween(Dot, {Position = UDim2.new(state and 1 or 0, state and -16 or 2, 0.5, -7), BackgroundColor3 = state and Color3.new(1,1,1) or Theme.TextMuted})
                pcall(callback, state)
            end

            zZz.UpdateCallbacks[flag] = SetState
            Hitbox.MouseButton1Click:Connect(function() SetState(not zZz.Flags[flag]) end)
            Hitbox.MouseEnter:Connect(function() Tween(TglBg, {BackgroundColor3 = Theme.Hover}) end)
            Hitbox.MouseLeave:Connect(function() Tween(TglBg, {BackgroundColor3 = Theme.ElementBg}) end)
            
            SetState(default)
        end

        function TabObj:CreateSlider(config)
            local name = config.Name or "Slider"
            local flag = config.Flag or name
            local min = config.Min or 0
            local max = config.Max or 100
            local default = config.Default or min
            local callback = config.Callback or function() end

            zZz.Flags[flag] = default

            local SldBg = Create("Frame", { Parent = Page, Size = UDim2.new(1, 0, 0, 55), BackgroundColor3 = Theme.ElementBg })
            Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = SldBg })
            Create("UIStroke", { Color = Theme.Border, Thickness = 1, Parent = SldBg })

            Create("TextLabel", { Parent = SldBg, Position = UDim2.new(0, 15, 0, 8), Size = UDim2.new(1, -60, 0, 15), BackgroundTransparency = 1, Text = name, TextColor3 = Theme.Text, Font = Fonts.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left })
            local ValLbl = Create("TextLabel", { Parent = SldBg, Position = UDim2.new(1, -50, 0, 8), Size = UDim2.new(0, 35, 0, 15), BackgroundTransparency = 1, Text = tostring(default), TextColor3 = Theme.Accent, Font = Fonts.Button, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Right })

            local Track = Create("Frame", { Parent = SldBg, Position = UDim2.new(0, 15, 0, 35), Size = UDim2.new(1, -30, 0, 6), BackgroundColor3 = Theme.Background })
            Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Track })
            local Fill = Create("Frame", { Parent = Track, Size = UDim2.new(0, 0, 1, 0), BackgroundColor3 = Theme.Accent })
            Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Fill })

            local function SetValue(val)
                val = math.clamp(math.floor(val), min, max)
                zZz.Flags[flag] = val
                ValLbl.Text = tostring(val)
                Tween(Fill, {Size = UDim2.new((val - min) / (max - min), 0, 1, 0)}, 0.1)
                pcall(callback, val)
            end

            zZz.UpdateCallbacks[flag] = SetValue

            local dragging = false
            Track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true; SetValue(min + (max - min) * math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1))
                end
            end)
            UIS.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
            UIS.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    SetValue(min + (max - min) * math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1))
                end
            end)
            SetValue(default)
        end

        function TabObj:CreateDropdown(config)
            local name = config.Name or "Dropdown"
            local flag = config.Flag or name
            local options = config.Options or {}
            local default = config.Default or options[1]
            local callback = config.Callback or function() end

            zZz.Flags[flag] = default

            local DropBg = Create("Frame", { Parent = Page, Size = UDim2.new(1, 0, 0, 40), BackgroundColor3 = Theme.ElementBg, ClipsDescendants = true })
            Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = DropBg })
            Create("UIStroke", { Color = Theme.Border, Thickness = 1, Parent = DropBg })

            local TopBtn = Create("TextButton", { Parent = DropBg, Size = UDim2.new(1,0,0,40), BackgroundTransparency = 1, Text = "" })
            local TitleL = Create("TextLabel", { Parent = TopBtn, Position = UDim2.new(0, 15, 0, 0), Size = UDim2.new(1, -60, 1, 0), BackgroundTransparency = 1, Text = name .. ": " .. tostring(default), TextColor3 = Theme.Text, Font = Fonts.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left })
            local Icon = Create("TextLabel", { Parent = TopBtn, Position = UDim2.new(1, -30, 0, 0), Size = UDim2.new(0, 20, 1, 0), BackgroundTransparency = 1, Text = "▼", TextColor3 = Theme.Accent, Font = Fonts.Button, TextSize = 14 })

            local List = Create("ScrollingFrame", { Parent = DropBg, Position = UDim2.new(0, 0, 0, 40), Size = UDim2.new(1, 0, 1, -40), BackgroundTransparency = 1, ScrollBarThickness = 2, ScrollBarImageColor3 = Theme.Accent })
            Create("UIListLayout", { Parent = List, SortOrder = Enum.SortOrder.LayoutOrder })

            local isOpen = false
            local function ToggleDrop()
                isOpen = not isOpen
                Tween(DropBg, {Size = UDim2.new(1, 0, 0, isOpen and math.min(40 + (#options * 30), 140) or 40)}, 0.2)
                Tween(Icon, {Rotation = isOpen and 180 or 0}, 0.2)
            end

            local function SetValue(val)
                zZz.Flags[flag] = val
                TitleL.Text = name .. ": " .. tostring(val)
                pcall(callback, val)
                if isOpen then ToggleDrop() end
            end

            zZz.UpdateCallbacks[flag] = SetValue
            TopBtn.MouseButton1Click:Connect(ToggleDrop)

            for _, opt in ipairs(options) do
                local OptBtn = Create("TextButton", { Parent = List, Size = UDim2.new(1, 0, 0, 30), BackgroundColor3 = Theme.Background, Text = tostring(opt), TextColor3 = Theme.TextMuted, Font = Fonts.Text, TextSize = 12 })
                OptBtn.MouseEnter:Connect(function() Tween(OptBtn, {BackgroundColor3 = Theme.Hover, TextColor3 = Theme.Text}) end)
                OptBtn.MouseLeave:Connect(function() Tween(OptBtn, {BackgroundColor3 = Theme.Background, TextColor3 = Theme.TextMuted}) end)
                OptBtn.MouseButton1Click:Connect(function() SetValue(opt) end)
            end
            SetValue(default)
        end

        return TabObj
    end

    -- ── ABA DE CONFIGURAÇÃO PADRÃO ──
    -- Usando o ícone de engrenagem do Roblox
    local ConfigTab = WindowObj:CreateTab("Settings", "rbxassetid://15003666245") 
