        function TabObj:CreateKeybind(config)
            local name = config.Name or "Keybind"
            local flag = config.Flag or name
            local default = config.Default or Enum.KeyCode.E
            local callback = config.Callback or function() end

            zZz.Flags[flag] = default

            local KeyBg = Create("Frame", { Parent = Page, Size = UDim2.new(1, 0, 0, 35), BackgroundColor3 = zZz.Theme.ElementBg })
            Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = KeyBg })
            Create("UIStroke", { Color = zZz.Theme.Border, Thickness = 1, Parent = KeyBg })

            Create("TextLabel", {
                Parent = KeyBg, Position = UDim2.new(0, 10, 0, 0), Size = UDim2.new(1, -100, 1, 0),
                BackgroundTransparency = 1, Text = name, TextColor3 = zZz.Theme.Text,
                Font = Enum.Font.GothamSemibold, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left
            })

            local KeyBtn = Create("TextButton", {
                Parent = KeyBg, Position = UDim2.new(1, -80, 0.5, -12), Size = UDim2.new(0, 70, 0, 24),
                BackgroundColor3 = zZz.Theme.MainBg, Text = default.Name, TextColor3 = zZz.Theme.Accent,
                Font = Enum.Font.GothamBold, TextSize = 12
            })
            Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = KeyBtn })
            Create("UIStroke", { Color = zZz.Theme.Border, Thickness = 1, Parent = KeyBtn })

            local listening = false
            local conn
            local function SetKey(k)
                zZz.Flags[flag] = k
                KeyBtn.Text = k.Name
                if flag == "UI_HideKey" then currentHideKey = k end
            end

            zZz.UpdateCallbacks[flag] = SetKey

            KeyBtn.MouseButton1Click:Connect(function()
                listening = true
                KeyBtn.Text = "..."
                if conn then conn:Disconnect() end
                conn = UIS.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        if input.KeyCode ~= Enum.KeyCode.Escape then
                            SetKey(input.KeyCode)
                            pcall(callback, input.KeyCode)
                        end
                        listening = false
                        conn:Disconnect()
                    end
                end)
            end)
        end

        return TabObj
    end

