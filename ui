            })
            Create("Frame", { Parent = Sep, Position = UDim2.new(0, 0, 1, -2), Size = UDim2.new(1, -20, 0, 1), BackgroundColor3 = Theme.Border })
        end

        function TabObj:CreateButton(text, callback)
            local BtnBg = Create("Frame", { Parent = Page, Size = UDim2.new(1, 0, 0, 40), BackgroundColor3 = Theme.ElementBg })
            Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = BtnBg })
            Create("UIStroke", { Color = Theme.Border, Thickness = 1, Parent = BtnBg })
            
            local Btn = Create("TextButton", {
                Parent = BtnBg, Size = UDim2.fromScale(1,1), BackgroundTransparency = 1,
                Text = text, TextColor3 = Theme.Text, Font = Fonts.Button, TextSize = 14
            })
            
