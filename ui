                local Track = Create("Frame", { Parent = SldBg, Position = UDim2.new(0, 12, 0, 30), Size = UDim2.new(1, -24, 0, 6), BackgroundColor3 = Theme.BgBase })
                Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Track })
                local Fill = Create("Frame", { Parent = Track, Size = UDim2.new(0, 0, 1, 0), BackgroundColor3 = Theme.Accent })
                Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Fill })

                local function SetValue(val)
                    val = math.clamp(math.floor(val), min, max); zZz.Flags[flag] = val; ValLbl.Text = tostring(val)
                    Tween(Fill, {Size = UDim2.new((val - min) / (max - min), 0, 1, 0)}, 0.1); pcall(callback, val)
                end
                zZz.UpdateCallbacks[flag] = SetValue

                local dragging = false
                Track.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true; SetValue(min + (max - min) * math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)) end end)
                UIS.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
                UIS.InputChanged:Connect(function(input) if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then SetValue(min + (max - min) * math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)) end end)
                SetValue(default)
            end

            return SecObj
        end
        return TabObj
    end

    -- ── ABA DE CONFIGURAÇÕES NATIVA ──
    local ConfigTab = WindowObj:CreateTab("Config", "Config") 
    local SysSec = ConfigTab:CreateSection("System Settings", "Left")
    
    local KeyBg = Create("Frame", { Parent = SysSec.Card, Size = UDim2.new(1, 0, 0, 36), BackgroundColor3 = Theme.Element, Parent = SysSec.Card.Parent }) -- Hack rápido pro layout
    KeyBg.Parent = SysSec:CreateToggle({Name = "UI Keybind Dummy"}).Parent.Parent -- Injetando
    KeyBg:ClearAllChildren(); Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = KeyBg }); Create("UIStroke", { Color = Theme.Border, Thickness = 1, Parent = KeyBg })
    Create("TextLabel", { Parent = KeyBg, Position = UDim2.new(0, 12, 0, 0), Size = UDim2.new(1, -100, 1, 0), BackgroundTransparency = 1, Text = "Hide UI Key", TextColor3 = Theme.Text, Font = Fonts.Normal, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left })
    local KeyBtn = Create("TextButton", { Parent = KeyBg, Position = UDim2.new(1, -80, 0.5, -12), Size = UDim2.new(0, 68, 0, 24), BackgroundColor3 = Theme.BgBase, Text = currentHideKey.Name, TextColor3 = Theme.Accent, Font = Fonts.Header, TextSize = 11 })
    Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = KeyBtn }); Create("UIStroke", { Color = Theme.Border, Thickness = 1, Parent = KeyBtn })
    
    local listening = false
    KeyBtn.MouseButton1Click:Connect(function()
        listening = true; KeyBtn.Text = "..."
        local conn; conn = UIS.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.Keyboard and inp.KeyCode ~= Enum.KeyCode.Escape then
                currentHideKey = inp.KeyCode; KeyBtn.Text = currentHideKey.Name
                listening = false; conn:Disconnect()
            end
        end)
    end)

    local SaveSec = ConfigTab:CreateSection("Save & Load", "Right")
    local tbBg = Create("Frame", { Parent = SaveSec.Card.Parent, Size = UDim2.new(1, 0, 0, 36), BackgroundColor3 = Theme.BgBase })
    Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = tbBg }); Create("UIStroke", { Color = Theme.Border, Thickness = 1, Parent = tbBg })
    local CfgNameBox = Create("TextBox", { Parent = tbBg, Size = UDim2.new(1, -20, 1, 0), Position = UDim2.new(0, 10, 0, 0), BackgroundTransparency = 1, Text = "Default", TextColor3 = Theme.Text, Font = Fonts.Normal, TextSize = 12, PlaceholderText = "Config Name...", TextXAlignment = Enum.TextXAlignment.Left })
    
    local btnRow = Create("Frame", { Parent = SaveSec.Card.Parent, Size = UDim2.new(1, 0, 0, 36), BackgroundTransparency = 1 })
    local sBtn = Create("TextButton", { Parent = btnRow, Size = UDim2.new(0.48, 0, 1, 0), BackgroundColor3 = Theme.Element, Text = "💾 Save", TextColor3 = Theme.Text, Font = Fonts.Header, TextSize = 12 })
    Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = sBtn }); Create("UIStroke", { Color = Theme.Border, Thickness = 1, Parent = sBtn })
    local lBtn = Create("TextButton", { Parent = btnRow, Size = UDim2.new(0.48, 0, 1, 0), Position = UDim2.new(0.52, 0, 0, 0), BackgroundColor3 = Theme.Element, Text = "📂 Load", TextColor3 = Theme.Text, Font = Fonts.Header, TextSize = 12 })
    Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = lBtn }); Create("UIStroke", { Color = Theme.Border, Thickness = 1, Parent = lBtn })
    
    sBtn.MouseButton1Click:Connect(function() WindowObj.SaveConfig(CfgNameBox.Text); Tween(sBtn, {BackgroundColor3=Theme.AccentDark}, 0.1); task.wait(0.1); Tween(sBtn, {BackgroundColor3=Theme.Element}, 0.1) end)
    lBtn.MouseButton1Click:Connect(function() WindowObj.LoadConfig(CfgNameBox.Text); Tween(lBtn, {BackgroundColor3=Theme.AccentDark}, 0.1); task.wait(0.1); Tween(lBtn, {BackgroundColor3=Theme.Element}, 0.1) end)

    return WindowObj
end

return zZz
