    -- ── SAVE/LOAD CONFIG ──
    function Win:SaveConfig()
        local data = {}
        for k, v in pairs(Library.Flags) do
            local t = type(v)
            if t == "boolean" or t == "number" or t == "string" then
                data[k] = v
            elseif t == "userdata" then
                -- Color3
                local ok2, r = pcall(function() return v.R end)
                if ok2 then
                    data[k] = {__type="Color3", r=v.R, g=v.G, b=v.B}
                end
                -- Enum
                local ok3, n = pcall(function() return v.Name end)
                if ok3 and not ok2 then
                    data[k] = {__type="Enum", name=n}
                end
            end
        end
        local json = HttpService:JSONEncode(data)
        local ok2 = pcall(writefile, Library.ConfigPath, json)
        return ok2
    end

    function Win:LoadConfig()
        local ok2, raw = pcall(readfile, Library.ConfigPath)
        if not ok2 or not raw then return false end
        local ok3, data = pcall(function() return HttpService:JSONDecode(raw) end)
        if not ok3 then return false end
        for k, v in pairs(data) do
            if type(v) == "table" then
                if v.__type == "Color3" then
                    Library.Flags[k] = Color3.new(v.r, v.g, v.b)
                elseif v.__type == "Enum" then
                    local enumOk, ev = pcall(function()
                        return Enum.KeyCode[v.name]
                    end)
                    if enumOk then Library.Flags[k] = ev end
                end
            else
                Library.Flags[k] = v
            end
        end
        return true
    end

    function Win:GetFlag(key)
        return Library.Flags[key]
    end

    function Win:Destroy()
        if ScreenGui and ScreenGui.Parent then
            ScreenGui:Destroy()
        end
    end

    return Win
end

