    local function RefreshSavesList()
        if not SavesListParent then return end
        for _, c in ipairs(SavesListParent:GetChildren()) do
            if c:IsA("Frame") then c:Destroy() end
        end
        local hasAny = false
        for name in pairs(Saves) do
            hasAny = true
            local item = Instance.new("Frame", SavesListParent)
            item.Size = UDim2.new(1, 0, 0, 40)
            item.BackgroundColor3 = C.Card
            item.BorderSizePixel = 0
            Instance.new("UICorner", item).CornerRadius = UDim.new(0, 7)
            local iStroke = Instance.new("UIStroke", item)
            iStroke.Color = C.Border; iStroke.Transparency = 0.4

            local ico = Instance.new("ImageLabel", item)
            ico.Size = UDim2.new(0, 18, 1, 0); ico.Position = UDim2.new(0, 8, 0, 0)
            ico.BackgroundTransparency = 1
            ico.Image = "rbxassetid://110476549897034"
            ico.ScaleType = Enum.ScaleType.Fit

            local nameLbl = Instance.new("TextLabel", item)
            nameLbl.Size = UDim2.new(1, -110, 1, 0)
            nameLbl.Position = UDim2.new(0, 32, 0, 0)
            nameLbl.BackgroundTransparency = 1
            nameLbl.Text = name
            nameLbl.TextColor3 = C.Text
            nameLbl.Font = Enum.Font.GothamMedium
            nameLbl.TextSize = 12
            nameLbl.TextXAlignment = 0
            nameLbl.TextTruncate = Enum.TextTruncate.AtEnd

            local loadBtn = Instance.new("TextButton", item)
            loadBtn.Size = UDim2.new(0, 46, 0, 24)
            loadBtn.Position = UDim2.new(1, -96, 0.5, -12)
            loadBtn.BackgroundColor3 = C.Primary
            loadBtn.Text = "LOAD"
            loadBtn.TextColor3 = C.Text
            loadBtn.Font = Enum.Font.GothamBold
            loadBtn.TextSize = 10
            loadBtn.BorderSizePixel = 0
            Instance.new("UICorner", loadBtn).CornerRadius = UDim.new(0, 5)

            local delBtn = Instance.new("TextButton", item)
            delBtn.Size = UDim2.new(0, 32, 0, 24)
            delBtn.Position = UDim2.new(1, -44, 0.5, -12)
            delBtn.BackgroundColor3 = Color3.fromRGB(190, 45, 65)
            delBtn.Text = "✕"
            delBtn.TextColor3 = C.Text
            delBtn.Font = Enum.Font.GothamBold
            delBtn.TextSize = 13
            delBtn.BorderSizePixel = 0
            Instance.new("UICorner", delBtn).CornerRadius = UDim.new(0, 5)

            loadBtn.MouseButton1Click:Connect(function()
                local cfg = Saves[name]
                if not cfg then return end
                for _, t in ipairs(Registry.toggles) do
                    if cfg.toggles and cfg.toggles[t.id] ~= nil then t.setState(cfg.toggles[t.id]) end
                    if cfg.keybinds and cfg.keybinds[t.id] ~= nil then t.setKeybind(cfg.keybinds[t.id]) end
                end
                for _, s in ipairs(Registry.sliders) do
                    if cfg.sliders and cfg.sliders[s.id] ~= nil then s.setValue(cfg.sliders[s.id]) end
                end
                if cfg.palette then
                    for key, hexStr in pairs(cfg.palette) do
                        local ok, col = pcall(HexToColor, hexStr)
                        if ok and col then
                            SetPaletteColor(key, col)
                            for _, cp in ipairs(Registry.colorpickers) do
                                if cp.paletteKey == key then cp.setColor(col) end
                            end
                        end
                    end
                end
            end)

            delBtn.MouseButton1Click:Connect(function()
                Saves[name] = nil
                item:Destroy()
                if NoSavesLabel then
                    local any = false
                    for _ in pairs(Saves) do any = true; break end
                    NoSavesLabel.Visible = not any
                end
            end)
        end
        if NoSavesLabel then NoSavesLabel.Visible = not hasAny end
    end

    local function DoSave(name)
        if name == "" then return false end
        local cfg = { toggles = {}, sliders = {}, keybinds = {}, palette = {} }
        for _, t in ipairs(Registry.toggles) do
            cfg.toggles[t.id]  = t.getState()
            cfg.keybinds[t.id] = t.getKeybind()
        end
        for _, s in ipairs(Registry.sliders) do
            cfg.sliders[s.id] = s.getValue()
        end
        for key, col in pairs(C) do
            cfg.palette[key] = ColorToHex(col)
        end
        Saves[name] = cfg
        RefreshSavesList()
        return true
    end

