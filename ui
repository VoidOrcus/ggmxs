                 InfoBox.BorderSizePixel = 0
                 Instance.new("UICorner", InfoBox).CornerRadius = UDim.new(0, 10)
                 RefColor("Dark", InfoBox, "BackgroundColor3")
            
                local ibS = Instance.new("UIStroke", InfoBox)
                ibS.Color = C.Border; ibS.Thickness = 1; ibS.Transparency = 0.4
                RefColor("Border", ibS, "Color")

                local InfoTitle = Instance.new("TextLabel", InfoBox)
                InfoTitle.Size = UDim2.new(1, -20, 0, 14)
                InfoTitle.Position = UDim2.new(0, 10, 0, 8)
                InfoTitle.BackgroundTransparency = 1
                InfoTitle.Text = "CONTENTS"
                InfoTitle.TextColor3 = C.Primary
                InfoTitle.Font = Enum.Font.GothamBlack
                InfoTitle.TextSize = 10
                InfoTitle.TextXAlignment = Enum.TextXAlignment.Left
                RefColor("Primary", InfoTitle, "TextColor3")

                local InfoCardsLayout = Instance.new("Frame", InfoBox)
                InfoCardsLayout.Size = UDim2.new(1, 0, 1, -26)
                InfoCardsLayout.Position = UDim2.new(0, 0, 0, 26)
                InfoCardsLayout.BackgroundTransparency = 1
                local I_Lay = Instance.new("UIListLayout", InfoCardsLayout)
                I_Lay.FillDirection = Enum.FillDirection.Horizontal
                I_Lay.Padding = UDim.new(0, 8)
                I_Lay.HorizontalAlignment = Enum.HorizontalAlignment.Center
                I_Lay.VerticalAlignment = Enum.VerticalAlignment.Center
                subObj.InfoLayout = InfoCardsLayout
            end

            -- ══════════════════════════════════════════════════
            -- ── STATISTICS LAYOUT ──
            -- ══════════════════════════════════════════════════
