            function subObj:_useColumn(preferredSide, estimatedHeight)
                preferredSide = preferredSide or "auto"
                if preferredSide == "left" then
                    return self.Left, "left"
                elseif preferredSide == "right" then
                    return self.Right, "right"
                end
                return (self._leftWeight <= self._rightWeight) and self.Left or self.Right, "auto"
            end

            if showContents then
